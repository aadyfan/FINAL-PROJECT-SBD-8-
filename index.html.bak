<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ephone — Toko Smartphone Online</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss-browser/4.1.13/index.global.min.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
  <style>
    :root{color-scheme:light;--ink:#0b1220;--muted:#64748b;--line:#e2e8f0;--soft:#f8fafc;--brand:#0f172a;--accent:#2563eb}*{scroll-behavior:smooth}body{font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:linear-gradient(180deg,#f8fafc 0%,#eef2f7 100%);color:var(--ink)}.glass{background:rgba(255,255,255,.88);backdrop-filter:blur(24px)}.hero{background:radial-gradient(circle at 78% 18%,rgba(37,99,235,.18) 0,transparent 30%),radial-gradient(circle at 8% 80%,rgba(16,185,129,.16) 0,transparent 32%),linear-gradient(135deg,#ffffff 0%,#f8fafc 54%,#eef2ff 100%)}.dark-card{background:radial-gradient(circle at 90% 10%,rgba(96,165,250,.30),transparent 25%),radial-gradient(circle at 10% 80%,rgba(16,185,129,.12),transparent 30%),linear-gradient(135deg,#020617,#111827 55%,#0f172a)}.card{background:rgba(255,255,255,.96);border:1px solid var(--line);box-shadow:0 18px 55px rgba(15,23,42,.07)}.lift{transition:transform .24s ease,box-shadow .24s ease,border-color .24s ease}.lift:hover{transform:translateY(-5px);box-shadow:0 30px 80px rgba(15,23,42,.14);border-color:#cbd5e1}.pill{border-radius:999px}.fade{animation:fade .22s ease both}.up{animation:up .35s cubic-bezier(.2,.8,.2,1) both}.scroll-clean::-webkit-scrollbar{width:9px;height:9px}.scroll-clean::-webkit-scrollbar-track{background:#f1f5f9;border-radius:999px}.scroll-clean::-webkit-scrollbar-thumb{background:#94a3b8;border-radius:999px}.scroll-clean::-webkit-scrollbar-thumb:hover{background:#64748b}.line-clamp-2{display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}.tab-active{background:#020617;color:#fff}.focus-ring:focus{outline:none;box-shadow:0 0 0 4px rgba(37,99,235,.16);border-color:#2563eb}.soft-grid{background-image:linear-gradient(rgba(15,23,42,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(15,23,42,.035) 1px,transparent 1px);background-size:28px 28px}.product-img-bg{background:radial-gradient(circle at 50% 30%,#ffffff 0,#eef2ff 42%,#f8fafc 78%)}.trust-item{background:rgba(255,255,255,.76);border:1px solid rgba(226,232,240,.9);box-shadow:0 16px 45px rgba(15,23,42,.06)}@keyframes fade{from{opacity:0}to{opacity:1}}@keyframes up{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}

    /* Hero slider fix: tetap terlihat walau JS belum jalan */
    .hero-animated{position:relative;overflow:hidden;isolation:isolate}.hero-animated::before{content:"";position:absolute;inset:-25%;z-index:-1;background:radial-gradient(circle at 16% 22%,rgba(37,99,235,.13),transparent 27%),radial-gradient(circle at 82% 28%,rgba(16,185,129,.12),transparent 27%),radial-gradient(circle at 52% 88%,rgba(99,102,241,.12),transparent 30%);filter:blur(12px);animation:heroGlowMove 14s ease-in-out infinite alternate}.reveal-up{opacity:0;transform:translateY(22px);filter:blur(7px);animation:revealUp .8s cubic-bezier(.2,.8,.2,1) forwards;animation-delay:var(--delay,0s)}.hero-float{animation:heroFloat 6.5s ease-in-out infinite;will-change:transform}.hero-card-inner{position:relative}.hero-card-inner::after{content:"";position:absolute;inset:0;border-radius:2rem;background:linear-gradient(115deg,transparent 8%,rgba(255,255,255,.13) 34%,transparent 54%);transform:translateX(-120%);animation:heroShine 6s ease-in-out infinite;pointer-events:none}.hero-slider-shell{overflow:hidden;border-radius:1.7rem}.hero-slider-track{display:flex;min-height:560px;transform:translateX(0);transition:transform .58s cubic-bezier(.2,.8,.2,1);will-change:transform}.hero-slide{display:block;flex:0 0 100%;min-width:100%;padding-top:4px}.hero-product-frame{background:linear-gradient(180deg,rgba(255,255,255,.96),rgba(226,232,240,.96));box-shadow:inset 0 1px 0 rgba(255,255,255,.85)}.hero-product-img{transition:transform .45s cubic-bezier(.2,.8,.2,1),filter .45s ease}.hero-float:hover .hero-product-img{transform:scale(1.045) translateY(-4px);filter:drop-shadow(0 24px 30px rgba(15,23,42,.23))}.hero-dot{height:.55rem;width:.55rem;border-radius:999px;background:rgba(255,255,255,.28);transition:width .25s ease,background .25s ease}.hero-dot.active{width:1.9rem;background:#fff}.hero-nav-btn{display:grid;height:2.35rem;width:2.35rem;place-items:center;border-radius:999px;background:rgba(255,255,255,.11);color:#fff;transition:background .2s ease,transform .2s ease}.hero-nav-btn:hover{background:rgba(255,255,255,.22);transform:translateY(-1px)}.promo-chip{background:linear-gradient(135deg,rgba(255,255,255,.17),rgba(255,255,255,.06));border:1px solid rgba(255,255,255,.14)}.promo-strip{background:linear-gradient(90deg,rgba(37,99,235,.18),rgba(16,185,129,.12),rgba(255,255,255,.10))}.slide-progress{height:3px;width:100%;overflow:hidden;border-radius:999px;background:rgba(255,255,255,.12)}.slide-progress span{display:block;height:100%;width:0;background:#fff}.slide-progress.play span{animation:slideProgress 5s linear forwards}.soft-pulse{animation:softPulse 2.4s ease-in-out infinite}.cta-soft{transition:transform .22s ease,box-shadow .22s ease}.cta-soft:hover{transform:translateY(-2px);box-shadow:0 22px 50px rgba(15,23,42,.18)}.trust-item{transition:transform .25s ease,box-shadow .25s ease,border-color .25s ease}.trust-item:hover{transform:translateY(-4px);box-shadow:0 24px 60px rgba(15,23,42,.11);border-color:#cbd5e1}.stat-card{opacity:0;transform:translateY(18px);animation:revealUp .7s cubic-bezier(.2,.8,.2,1) forwards;animation-delay:var(--delay,.05s)}.stat-icon{transition:transform .25s ease}.stat-card:hover .stat-icon{transform:rotate(-8deg) scale(1.08)}@keyframes revealUp{to{opacity:1;transform:translateY(0);filter:blur(0)}}@keyframes heroFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}@keyframes heroShine{0%,46%{transform:translateX(-120%)}70%,100%{transform:translateX(120%)}}@keyframes heroGlowMove{0%{transform:translate3d(-2%,0,0) scale(1)}100%{transform:translate3d(2%,-2%,0) scale(1.04)}}@keyframes softPulse{0%,100%{box-shadow:0 0 0 0 rgba(255,255,255,.16);opacity:.92}50%{box-shadow:0 0 0 8px rgba(255,255,255,0);opacity:1}}@keyframes slideProgress{from{width:0}to{width:100%}}.hero-right-fix{display:block!important;opacity:1!important;transform:translateY(0)!important;filter:none!important;min-width:0}.hero-right-fix [data-hero-widget]{min-height:620px}.hero-right-fix .hero-slider-shell{min-height:560px}.hero-right-fix .hero-slider-track{min-height:560px}
@media print{nav,footer,#toast,.no-print{display:none!important}body{background:#fff!important}.invoice-print{box-shadow:none!important;border:0!important}.invoice-print *{color:#0f172a!important}}
@media (prefers-reduced-motion:reduce){.reveal-up,.hero-float,.soft-pulse,.hero-card-inner::after,.stat-card,.hero-animated::before,.slide-progress span{animation:none!important;opacity:1!important;transform:none!important;filter:none!important}.hero-slider-track{transition:none!important}*{scroll-behavior:auto!important}}
  </style>
</head>
<body>
  <nav class="sticky top-0 z-50 border-b border-slate-200 glass">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 lg:px-6">
      <button data-page="home" class="nav-link flex items-center gap-3 text-left">
        <span class="grid h-11 w-11 place-items-center rounded-2xl bg-slate-950 text-white shadow-lg shadow-slate-300"><i class="fa-solid fa-mobile-screen-button"></i></span>
        <span><span class="block text-xl font-black tracking-tight">ephone</span><span class="block text-[11px] font-black uppercase tracking-[.22em] text-slate-400">toko smartphone</span></span>
      </button>
      <div class="hidden items-center gap-1 lg:flex">
        <button data-page="home" class="nav-link pill px-4 py-2 text-sm font-black text-slate-600 hover:bg-slate-950 hover:text-white">Home</button>
        <button data-page="catalog" class="nav-link pill px-4 py-2 text-sm font-black text-slate-600 hover:bg-slate-950 hover:text-white">Katalog</button>
        <button data-page="wishlist" class="nav-link pill px-4 py-2 text-sm font-black text-slate-600 hover:bg-slate-950 hover:text-white">Wishlist <span id="nav-wishlist-badge">0</span></button>
        <button data-page="history" class="nav-link pill px-4 py-2 text-sm font-black text-slate-600 hover:bg-slate-950 hover:text-white">Pesanan</button>
        <button data-page="admin" class="nav-link pill px-4 py-2 text-sm font-black text-slate-600 hover:bg-slate-950 hover:text-white">Admin</button>
      </div>
      <div class="flex items-center gap-2">
        <button data-page="cart" class="nav-link relative rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-black hover:border-slate-950"><i class="fa-solid fa-bag-shopping"></i><span id="cart-floating" class="absolute -right-1 -top-1 grid h-5 min-w-5 place-items-center rounded-full bg-slate-950 px-1 text-[10px] text-white">0</span></button>
        <button id="drawer-open" class="rounded-2xl bg-slate-950 px-5 py-3 text-sm font-black text-white shadow-lg shadow-slate-300 hover:bg-slate-800">Menu <i class="fa-solid fa-bars ml-2"></i></button>
      </div>
    </div>
  </nav>

  <aside id="account-drawer" class="fixed inset-y-0 right-0 z-[100] hidden w-full max-w-md border-l border-slate-200 bg-white shadow-2xl">
    <div class="flex h-full flex-col">
      <div class="dark-card p-6 text-white">
        <div class="flex items-start justify-between gap-4">
          <div><p class="text-xs font-black uppercase tracking-[.24em] text-slate-400">Akun Saya</p><h2 id="drawer-name" class="mt-2 text-2xl font-black">Belum login</h2><p id="drawer-email" class="mt-1 text-sm text-slate-300">Masuk untuk mengelola belanja dan pesanan</p></div>
          <button id="drawer-close" class="rounded-full bg-white/10 px-3 py-2 text-white hover:bg-white/20"><i class="fa-solid fa-xmark"></i></button>
        </div>
      </div>
      <div class="scroll-clean flex-1 overflow-y-auto p-4">
        <p class="px-3 pb-2 text-xs font-black uppercase tracking-[.18em] text-slate-400">Masuk akun</p>
        <button data-page="login" class="drawer-link nav-link flex w-full items-center gap-3 rounded-3xl px-4 py-4 text-left font-black hover:bg-blue-50"><i class="fa-solid fa-user text-blue-600"></i> Login Pelanggan</button>
        <button data-page="login-admin" class="drawer-link nav-link flex w-full items-center gap-3 rounded-3xl px-4 py-4 text-left font-black hover:bg-slate-100"><i class="fa-solid fa-user-shield text-slate-950"></i> Login Admin</button>
        <p class="mt-5 px-3 pb-2 text-xs font-black uppercase tracking-[.18em] text-slate-400">Pelanggan</p>
        <button data-page="profile" class="drawer-link nav-link flex w-full items-center justify-between rounded-3xl px-4 py-4 text-left font-black hover:bg-slate-100"><span><i class="fa-solid fa-id-card mr-3 text-slate-700"></i> Profil</span><i class="fa-solid fa-chevron-right text-xs text-slate-400"></i></button>
        <button data-page="wishlist" class="drawer-link nav-link flex w-full items-center justify-between rounded-3xl px-4 py-4 text-left font-black hover:bg-rose-50"><span><i class="fa-solid fa-heart mr-3 text-rose-500"></i> Wishlist</span><span id="drawer-wishlist-badge" class="rounded-full bg-rose-100 px-3 py-1 text-xs text-rose-600">0</span></button>
        <button data-page="history" class="drawer-link nav-link flex w-full items-center justify-between rounded-3xl px-4 py-4 text-left font-black hover:bg-emerald-50"><span><i class="fa-solid fa-receipt mr-3 text-emerald-600"></i> Riwayat Pesanan</span><i class="fa-solid fa-chevron-right text-xs text-slate-400"></i></button>
        <button data-page="cart" class="drawer-link nav-link flex w-full items-center justify-between rounded-3xl px-4 py-4 text-left font-black hover:bg-slate-100"><span><i class="fa-solid fa-bag-shopping mr-3 text-slate-700"></i> Keranjang</span><span id="drawer-cart-badge" class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-700">0</span></button>
        <p class="mt-5 px-3 pb-2 text-xs font-black uppercase tracking-[.18em] text-slate-400">Admin</p>
        <button data-page="admin" class="drawer-link nav-link flex w-full items-center justify-between rounded-3xl bg-slate-950 px-4 py-4 text-left font-black text-white hover:bg-slate-800"><span><i class="fa-solid fa-chart-line mr-3"></i> Dashboard Admin</span><i class="fa-solid fa-chevron-right text-xs text-slate-400"></i></button>
        <div class="my-5 border-t border-slate-100"></div>
        <button data-page="logout" class="drawer-link nav-link flex w-full items-center gap-3 rounded-3xl px-4 py-4 text-left font-black text-rose-600 hover:bg-rose-50"><i class="fa-solid fa-right-from-bracket"></i> Logout Pelanggan</button>
        <button data-page="logout-admin" class="drawer-link nav-link flex w-full items-center gap-3 rounded-3xl px-4 py-4 text-left font-black text-rose-600 hover:bg-rose-50"><i class="fa-solid fa-power-off"></i> Logout Admin</button>
      </div>
    </div>
  </aside>
  <div id="drawer-backdrop" class="fixed inset-0 z-[90] hidden bg-black/40 backdrop-blur-sm"></div>

  <main id="app-content" class="min-h-screen"></main>
  <footer class="border-t border-slate-200 bg-white"><div class="mx-auto grid max-w-7xl gap-8 px-4 py-10 text-sm text-slate-500 md:grid-cols-[1.2fr_1fr_1fr] lg:px-6"><div><b class="block text-xl text-slate-950">ephone</b><p class="mt-2 max-w-sm leading-6">Toko smartphone online dengan katalog, keranjang, pembayaran, riwayat pesanan, dan dashboard admin.</p></div><div><b class="text-slate-950">Layanan</b><p class="mt-2 leading-6">Garansi resmi, pengiriman nasional, dan pilihan pembayaran fleksibel.</p></div><div><b class="text-slate-950">Bantuan</b><p class="mt-2 leading-6">Senin–Sabtu, 09.00–18.00 WIB<br>support@ephone.id</p></div></div></footer>

<script>
const LS = { user:'ephone_pro_user', admin:'ephone_pro_admin' };
const FALLBACK_IMG = 'data:image/svg+xml;charset=UTF-8,' + encodeURIComponent(`<svg xmlns="http://www.w3.org/2000/svg" width="900" height="760" viewBox="0 0 900 760"><rect width="900" height="760" fill="#f8fafc"/><rect x="315" y="110" width="270" height="500" rx="48" fill="#0f172a"/><rect x="337" y="135" width="226" height="450" rx="34" fill="#ffffff"/><circle cx="450" cy="160" r="7" fill="#0f172a"/><text x="450" y="680" text-anchor="middle" font-family="Arial" font-size="46" font-weight="900" fill="#0f172a">ephone</text></svg>`);
window.FALLBACK_IMG = FALLBACK_IMG;
document.addEventListener('error', e => { if(e.target && e.target.tagName === 'IMG' && e.target.src !== FALLBACK_IMG){ e.target.src = FALLBACK_IMG; } }, true);
const S = {
  currentPage:'loading', currentProductId:null, selectedQty:1, selectedVariantByProductId:{}, adminTab:'overview', justAddedProductId:null, invoiceOrderId:null, heroTimer:null,
  products:[], variants:[], specs:[], brands:[], categories:[], ramOptions:[], storageOptions:[], cartItems:[], wishlist:[], orders:[], adminOrders:[], report:null,
  search:'', sort:'recommended', filters:{brands:[], categories:[], rams:[], storages:[], minPrice:0, maxPrice:30000000, stockOnly:false},
  currentUser: readLS(LS.user, null), currentAdmin: readLS(LS.admin, null),
  checkout:{address:'', paymentMethod:'transfer_bank', transferBank:'BCA', phone:'', name:''}
};

function readLS(key, fallback){ try { const v = localStorage.getItem(key); return v ? JSON.parse(v) : fallback; } catch { return fallback; } }
function saveUser(){ S.currentUser ? localStorage.setItem(LS.user, JSON.stringify(S.currentUser)) : localStorage.removeItem(LS.user); S.currentAdmin ? localStorage.setItem(LS.admin, JSON.stringify(S.currentAdmin)) : localStorage.removeItem(LS.admin); }
function rupiah(v){ return new Intl.NumberFormat('id-ID',{style:'currency',currency:'IDR',maximumFractionDigits:0}).format(Number(v||0)); }
function esc(s){ return String(s ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c])); }
function idOfProduct(p){ return p?.product_id || p?.id; }
function idOfVariant(v){ return Number(v?.variant_id || v?.id); }
function findProduct(id){ return S.products.find(p => idOfProduct(p) == id); }
function variantsOf(pid){ return S.variants.filter(v => v.product_id == pid); }
function findVariant(vid){ return S.variants.find(v => idOfVariant(v) == vid); }
function selectedVariant(pid){ const vs = variantsOf(pid); const firstAvailable = vs.find(v => Number(v.stock)>0) || vs[0]; const sid = S.selectedVariantByProductId[pid] || (firstAvailable && idOfVariant(firstAvailable)); return vs.find(v => idOfVariant(v) == sid) || firstAvailable; }
function specOf(pid){ return S.specs.find(x => x.product_id == pid) || {}; }
function imgOf(p){ return p?.image_url || `assets/product-images/${idOfProduct(p)}.svg`; }
function firstVariantForProduct(pid){ return variantsOf(pid)[0]; }
function wishVariantIds(){ return new Set(S.wishlist.map(w => Number(w.variant_id))); }
function cartCount(){ return S.cartItems.reduce((a,b)=>a+Number(b.quantity||0),0); }
function wishCount(){ return S.wishlist.length; }
function uniqueSorted(arr){ return [...new Set(arr.filter(Boolean).map(x=>String(x).trim()).filter(Boolean))].sort((a,b)=>a.localeCompare(b,'id',{numeric:true,sensitivity:'base'})); }
function stockMeta(qty){ qty=Number(qty||0); if(qty<=0) return {label:'Habis', cls:'bg-rose-50 text-rose-700', dot:'bg-rose-500'}; if(qty<=3) return {label:'Hampir habis', cls:'bg-rose-50 text-rose-700', dot:'bg-rose-500'}; if(qty<=10) return {label:'Stok terbatas', cls:'bg-amber-50 text-amber-700', dot:'bg-amber-500'}; return {label:'Stok tersedia', cls:'bg-emerald-50 text-emerald-700', dot:'bg-emerald-500'}; }
function statusInfo(s){ const m={pending:['Menunggu pembayaran','Pesanan dibuat, pelanggan perlu menyelesaikan pembayaran.','bg-amber-50 text-amber-700'],confirmed:['Pembayaran dikonfirmasi','Pembayaran diterima dan pesanan diproses.','bg-blue-50 text-blue-700'],shipped:['Dikirim','Pesanan sedang dalam pengiriman.','bg-indigo-50 text-indigo-700'],delivered:['Selesai','Pesanan sudah diterima pelanggan.','bg-emerald-50 text-emerald-700'],cancelled:['Dibatalkan','Pesanan dibatalkan.','bg-rose-50 text-rose-700']}; const v=m[s]||[s||'-','Status pesanan belum tersedia.','bg-slate-100 text-slate-600']; return {label:v[0],desc:v[1],cls:v[2]}; }
function statusTimeline(status){ const steps=['pending','confirmed','shipped','delivered']; const active=status==='cancelled'?-1:Math.max(0,steps.indexOf(status)); if(status==='cancelled') return `<div class="rounded-2xl bg-rose-50 p-4 text-sm font-bold text-rose-700"><i class="fa-solid fa-ban mr-2"></i>Pesanan dibatalkan. Tidak masuk ke proses pengiriman.</div>`; return `<div class="grid gap-2 sm:grid-cols-4">${steps.map((x,i)=>{const inf=statusInfo(x); const done=i<=active; return `<div class="rounded-2xl ${done?'bg-slate-950 text-white':'bg-slate-100 text-slate-500'} p-3 text-xs font-black"><span class="mb-2 grid h-7 w-7 place-items-center rounded-full ${done?'bg-white text-slate-950':'bg-white text-slate-400'}">${done?'<i class="fa-solid fa-check"></i>':i+1}</span>${inf.label}</div>`}).join('')}</div>`; }
function resetCatalogFilters(){ S.search=''; S.sort='recommended'; S.filters={brands:S.brands.map(b=>b.brand_name),categories:S.categories.map(c=>c.category_name),rams:[...S.ramOptions],storages:[...S.storageOptions],minPrice:0,maxPrice:30000000,stockOnly:false}; }
function toast(msg, type='success'){
  let c=document.getElementById('toast'); if(!c){c=document.createElement('div');c.id='toast';c.className='fixed right-4 top-24 z-[999] flex max-w-sm flex-col gap-2';document.body.appendChild(c)}
  const bg=type==='error'?'bg-rose-600':type==='info'?'bg-slate-950':'bg-emerald-600'; const t=document.createElement('div');
  t.className=`up rounded-2xl ${bg} px-4 py-3 text-sm font-black text-white shadow-xl`; t.textContent=msg; c.appendChild(t); setTimeout(()=>{t.style.opacity='0'; t.style.transform='translateY(-8px)'; setTimeout(()=>t.remove(),250)},3000);
}
async function postJSON(url, payload){ const r=await fetch(url,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload),cache:'no-store'}); const data=await r.json(); if(!data.success) throw new Error(data.message || 'Request gagal.'); return data; }
async function getJSON(url){ const sep=url.includes('?')?'&':'?'; const r=await fetch(`${url}${sep}_t=${Date.now()}`,{cache:'no-store'}); const data=await r.json(); if(!data.success) throw new Error(data.message || 'Request gagal.'); return data; }
function setDrawer(open){ document.getElementById('account-drawer').classList.toggle('hidden', !open); document.getElementById('drawer-backdrop').classList.toggle('hidden', !open); }
document.getElementById('drawer-open').onclick=()=>setDrawer(true); document.getElementById('drawer-close').onclick=()=>setDrawer(false); document.getElementById('drawer-backdrop').onclick=()=>setDrawer(false);
function syncNav(){ document.querySelectorAll('.nav-link').forEach(btn => btn.onclick = () => handleNav(btn.dataset.page)); }
function updateUI(){
  ['nav-cart-badge','cart-floating','drawer-cart-badge'].forEach(id=>{const el=document.getElementById(id); if(el) el.textContent=cartCount()});
  ['nav-wishlist-badge','drawer-wishlist-badge'].forEach(id=>{const el=document.getElementById(id); if(el) el.textContent=wishCount()});
  const who=S.currentAdmin || S.currentUser; document.getElementById('drawer-name').textContent = who?.name || who?.full_name || 'Belum login'; document.getElementById('drawer-email').textContent = who ? `${who.email} • ${who.role}` : 'Masuk untuk mengelola belanja dan pesanan';
  syncNav();
}
function handleNav(page){ setDrawer(false); if(page==='logout'){ S.currentUser=null; S.cartItems=[]; S.wishlist=[]; saveUser(); toast('Customer logout.','info'); return renderPage('home'); } if(page==='logout-admin'){ S.currentAdmin=null; saveUser(); toast('Admin logout.','info'); return renderPage('home'); } renderPage(page || 'home'); }

function loading(title='Memuat data...', sub='Mohon tunggu sebentar.'){ return `<section class="mx-auto max-w-7xl px-4 py-16 lg:px-6"><div class="card rounded-[2rem] p-10 text-center"><div class="mx-auto mb-5 grid h-14 w-14 animate-pulse place-items-center rounded-2xl bg-slate-950 text-white"><i class="fa-solid fa-database"></i></div><h1 class="text-2xl font-black">${esc(title)}</h1><p class="mt-2 text-slate-500">${esc(sub)}</p></div></section>`; }
function errorBox(title, msg){ return `<section class="mx-auto max-w-7xl px-4 py-16 lg:px-6"><div class="rounded-[2rem] border border-rose-200 bg-rose-50 p-8"><h1 class="text-2xl font-black text-rose-700">${esc(title)}</h1><p class="mt-2 text-rose-600">${esc(msg)}</p><button data-page="home" class="nav-link mt-6 rounded-2xl bg-rose-600 px-5 py-3 font-black text-white">Kembali</button></div></section>`; }
function emptyState(title, msg, action='catalog'){ return `<div class="card rounded-[2rem] p-10 text-center"><div class="mx-auto mb-4 grid h-14 w-14 place-items-center rounded-2xl bg-slate-100 text-slate-500"><i class="fa-solid fa-box-open"></i></div><h2 class="text-2xl font-black">${esc(title)}</h2><p class="mx-auto mt-2 max-w-xl text-slate-500">${esc(msg)}</p><button data-page="${action}" class="nav-link mt-6 rounded-2xl bg-slate-950 px-6 py-3 font-black text-white">Lihat catalog</button></div>`; }

async function init(){
  document.getElementById('app-content').innerHTML = loading('Menyiapkan katalog...', 'Produk, stok, dan akun sedang dimuat.');
  try {
    await fetchProduk(false);
    if(S.currentUser) await Promise.allSettled([loadCart(), loadWishlist()]);
    renderPage('home');
    updateUI();
  } catch(e){ document.getElementById('app-content').innerHTML = errorBox('Gagal memuat data', e.message + ' Pastikan server lokal aktif dan konfigurasi koneksi sudah benar.'); updateUI(); }
}
async function fetchProduk(renderNext=true){
  const d=await getJSON('api_get_product.php');
  S.products=d.data.products||[]; S.variants=d.data.variants||[]; S.specs=d.data.specs||[]; S.brands=d.data.brands||[]; S.categories=d.data.categories||[];
  S.ramOptions = uniqueSorted(S.variants.map(v=>v.ram));
  S.storageOptions = uniqueSorted(S.variants.map(v=>v.storage));
  if(!S.filters.brands.length) S.filters.brands = S.brands.map(b=>b.brand_name);
  if(!S.filters.categories.length) S.filters.categories = S.categories.map(c=>c.category_name);
  if(!Array.isArray(S.filters.rams) || !S.filters.rams.length) S.filters.rams = [...S.ramOptions];
  if(!Array.isArray(S.filters.storages) || !S.filters.storages.length) S.filters.storages = [...S.storageOptions];
  if(renderNext) renderPage(typeof renderNext==='string'?renderNext:S.currentPage);
}
async function loadCart(){ if(!S.currentUser) {S.cartItems=[]; updateUI(); return;} const d=await getJSON(`api_cart.php?user_id=${encodeURIComponent(S.currentUser.user_id)}`); S.cartItems=d.data.cart||[]; updateUI(); }
async function loadWishlist(){ if(!S.currentUser) {S.wishlist=[]; updateUI(); return;} const d=await getJSON(`api_wishlist.php?user_id=${encodeURIComponent(S.currentUser.user_id)}`); S.wishlist=d.data.wishlist||[]; updateUI(); }
function requireUser(){ if(!S.currentUser){ toast('Silakan login pelanggan untuk melanjutkan.', 'error'); renderPage('login'); return false; } return true; }
function requireAdmin(){ if(!S.currentAdmin){ toast('Login admin dulu.', 'error'); renderPage('login-admin'); return false; } return true; }

function renderPage(page){
  S.currentPage=page; const app=document.getElementById('app-content');
  const routes={home:homePage,catalog:catalogPage,detail:detailPage,cart:cartPage,checkout:checkoutPage,wishlist:wishlistPage,history:historyPage,invoice:invoicePage,login:()=>loginPage('customer'),'login-admin':()=>loginPage('admin'),profile:profilePage,admin:adminPage};
  app.innerHTML=(routes[page]||homePage)(); bindPage(page); window.scrollTo({top:0,behavior:'smooth'}); updateUI();
}

function homePage(){
  const featured = [...S.products].sort((a,b)=>b.stock_total-a.stock_total).slice(0,8);
  const premium = S.products.filter(p=>String(p.category).toLowerCase().includes('flagship') || /pro|max|ultra|fold|flip/i.test(p.name||'')).sort((a,b)=>Number(b.stock_total||0)-Number(a.stock_total||0)).slice(0,6);
  let heroProducts = premium.length ? premium : [...S.products].sort((a,b)=>Number(b.stock_total||0)-Number(a.stock_total||0)).slice(0,6);
  if(!heroProducts.length){ heroProducts = [{product_id:'p001',name:'Apple iPhone 17 Pro Max',brand:'Apple',category:'Flagship',price:24999000,stock_total:20,rating:'4.9',tagline:'Performa premium untuk kerja, konten, belajar, dan hiburan harian.'}]; }
  const totalStok = S.variants.reduce((a,b)=>a+Number(b.stock||0),0);
  const promoLines = [
    'Pilihan smartphone favorit dengan stok tersedia dan varian lengkap.',
    'Cek warna, RAM, storage, harga, dan stok sebelum checkout.',
    'Cocok untuk upgrade harian, kerja, belajar, gaming ringan, dan konten.',
    'Belanja lebih praktis dengan wishlist, keranjang, dan riwayat pesanan.'
  ];
  const heroSlides = heroProducts.map((p,i)=>{
    const promo = i===0 ? 'Produk pilihan minggu ini' : i===1 ? 'Rekomendasi performa tinggi' : i===2 ? 'Upgrade paling dicari' : i===3 ? 'Desain premium' : 'Pilihan katalog terbaik';
    const badges = [esc(p.brand||'Brand resmi'), esc(p.category||'Smartphone'), Number(p.stock_total)>0 ? 'Ready stock' : 'Cek stok'];
    return `<article class="hero-slide" data-slide="${i}"><div class="grid h-full content-between gap-4"><div><div class="flex items-center justify-between gap-3"><p class="text-sm font-black uppercase tracking-[.18em] text-slate-400">Produk Pilihan</p><span class="soft-pulse rounded-full bg-white/10 px-3 py-1 text-xs font-black text-slate-200">${promo}</span></div><h2 class="mt-4 text-3xl font-black leading-tight md:text-4xl">${esc(p.name||'Smartphone pilihan')}</h2><p class="mt-2 min-h-12 text-sm leading-6 text-slate-300 md:text-base">${esc(p.tagline||promoLines[i%promoLines.length])}</p><div class="mt-4 flex flex-wrap gap-2">${badges.map(b=>`<span class="promo-chip rounded-full px-3 py-1 text-[11px] font-black uppercase tracking-wide text-slate-200">${b}</span>`).join('')}</div></div><div class="hero-product-frame rounded-[1.7rem] p-3"><img src="${imgOf(p)}" class="hero-product-img mx-auto h-72 w-full object-contain md:h-80" alt="${esc(p.name||'produk')}"></div><div class="promo-strip rounded-3xl p-4"><div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between"><span><small class="block text-xs font-black uppercase tracking-[.15em] text-slate-300">Mulai dari</small><b class="block text-2xl font-black">${rupiah(p.price)}</b><small class="text-slate-300">Stok ${p.stock_total||0} unit • rating ${p.rating||'0.0'}</small></span><button data-page="detail" data-product="${idOfProduct(p)}" class="detail-go cta-soft rounded-2xl bg-white px-5 py-3 font-black text-slate-950">Lihat detail</button></div></div></div></article>`;
  }).join('');
  const dots = heroProducts.map((_,i)=>`<button class="hero-dot ${i===0?'active':''}" data-hero-dot="${i}" aria-label="Pilih produk ${i+1}"></button>`).join('');
  return `<section class="hero hero-animated soft-grid"><div class="mx-auto grid max-w-7xl items-center gap-10 px-4 py-16 lg:grid-cols-2 lg:px-6 lg:py-20"><div><p class="reveal-up inline-flex rounded-full bg-white px-4 py-2 text-xs font-black uppercase tracking-[.2em] text-slate-500 shadow-sm ring-1 ring-slate-200" style="--delay:.04s">Smartphone resmi untuk kebutuhan harian</p><h1 class="reveal-up mt-6 max-w-4xl text-5xl font-black tracking-tight text-slate-950 md:text-7xl" style="--delay:.14s">Temukan smartphone yang pas untuk kerja, belajar, dan hiburan.</h1><p class="reveal-up mt-5 max-w-2xl text-lg leading-8 text-slate-600" style="--delay:.24s">Belanja lebih nyaman dengan katalog lengkap, pilihan varian, stok tersedia, wishlist, keranjang, checkout, dan riwayat pesanan dalam satu tempat.</p><div class="reveal-up mt-8 flex flex-wrap gap-3" style="--delay:.34s"><button data-page="catalog" class="nav-link cta-soft rounded-2xl bg-slate-950 px-6 py-4 font-black text-white shadow-xl shadow-slate-300">Belanja sekarang</button><button data-page="wishlist" class="nav-link cta-soft rounded-2xl border border-slate-300 bg-white px-6 py-4 font-black text-slate-950">Lihat wishlist</button></div><div class="reveal-up mt-6 rounded-3xl border border-slate-200 bg-white/75 p-4 shadow-sm" style="--delay:.40s"><p class="text-xs font-black uppercase tracking-[.18em] text-slate-400">Promo belanja</p><p class="mt-2 text-sm font-bold leading-6 text-slate-700">Pilih varian, cek stok, simpan ke wishlist, lalu checkout tanpa ribet. Semua produk ditampilkan dengan harga dan stok yang jelas.</p></div><div class="mt-8 grid max-w-2xl gap-3 sm:grid-cols-3"><div class="trust-item reveal-up rounded-3xl p-4" style="--delay:.48s"><i class="fa-solid fa-shield-halved text-slate-950"></i><b class="mt-2 block text-sm">Garansi resmi</b><small class="text-slate-500">Produk bergaransi</small></div><div class="trust-item reveal-up rounded-3xl p-4" style="--delay:.56s"><i class="fa-solid fa-truck-fast text-slate-950"></i><b class="mt-2 block text-sm">Pengiriman nasional</b><small class="text-slate-500">Estimasi ongkir jelas</small></div><div class="trust-item reveal-up rounded-3xl p-4" style="--delay:.64s"><i class="fa-solid fa-credit-card text-slate-950"></i><b class="mt-2 block text-sm">Pembayaran fleksibel</b><small class="text-slate-500">Transfer, e-wallet, kartu, COD</small></div></div></div><div class="hero-right-fix card hero-float rounded-[2.5rem] p-5"><div data-hero-widget class="dark-card hero-card-inner relative overflow-hidden rounded-[2rem] p-5 text-white"><div class="slide-progress mb-4"><span></span></div><div class="hero-slider-shell"><div data-hero-slider class="hero-slider-track">${heroSlides}</div></div><div class="mt-4 flex items-center justify-between gap-3"><button data-hero-prev class="hero-nav-btn" aria-label="Produk sebelumnya"><i class="fa-solid fa-arrow-left"></i></button><div class="flex items-center justify-center gap-2">${dots}</div><button data-hero-next class="hero-nav-btn" aria-label="Produk berikutnya"><i class="fa-solid fa-arrow-right"></i></button></div></div></div></div></section><section class="mx-auto max-w-7xl px-4 py-12 lg:px-6"><div class="grid gap-4 md:grid-cols-4">${metricCard('Produk aktif',S.products.length,'fa-mobile-screen-button',.06)}${metricCard('Pilihan varian',S.variants.length,'fa-layer-group',.14)}${metricCard('Stok tersedia',totalStok,'fa-boxes-stacked',.22)}${metricCard('Brand pilihan',S.brands.length,'fa-copyright',.30)}</div><div class="mt-14 flex flex-col justify-between gap-4 md:flex-row md:items-end"><div><p class="text-sm font-black uppercase tracking-[.2em] text-slate-400">Katalog pilihan</p><h2 class="mt-2 text-4xl font-black">Produk unggulan</h2><p class="mt-2 text-slate-500">Rekomendasi smartphone dengan stok terbaik.</p></div><button data-page="catalog" class="nav-link cta-soft rounded-2xl bg-white px-5 py-3 font-black ring-1 ring-slate-200">Lihat semua produk</button></div><div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">${featured.map(productCard).join('')}</div></section>`;
}

function metricCard(label,value,icon,delay=.06){ const numeric = typeof value === 'number' && Number.isFinite(value); const numberHTML = numeric ? `<b class="js-count block text-2xl font-black" data-count="${value}">0</b>` : `<b class="block text-2xl font-black">${value}</b>`; return `<div class="card stat-card rounded-3xl p-5" style="--delay:${delay}s"><div class="flex items-center gap-4"><span class="stat-icon grid h-12 w-12 place-items-center rounded-2xl bg-slate-950 text-white"><i class="fa-solid ${icon}"></i></span><span>${numberHTML}<small class="text-slate-500">${esc(label)}</small></span></div></div>`; }

function productCard(p){
  const v=selectedVariant(idOfProduct(p))||{}; const liked=wishVariantIds().has(Number(v.variant_id)); const meta=stockMeta(p.stock_total);
  const variantLine = variantsOf(idOfProduct(p)).slice(0,3).map(x=>`${x.ram}/${x.storage}`).join(' • ');
  return `<article class="product-card card lift group overflow-hidden rounded-[2rem]"><button data-product="${idOfProduct(p)}" class="detail-go product-img-bg block w-full p-5"><img src="${imgOf(p)}" alt="${esc(p.name)}" class="h-56 w-full rounded-[1.5rem] object-contain transition duration-300 group-hover:scale-[1.035]"></button><div class="p-5"><div class="mb-3 flex items-center justify-between gap-2"><span class="rounded-full bg-slate-100 px-3 py-1 text-[11px] font-black uppercase tracking-wide text-slate-600">${esc(p.brand)}</span><span class="rounded-full ${meta.cls} px-3 py-1 text-[11px] font-black"><i class="fa-solid fa-circle mr-1 text-[7px]"></i>${meta.label}${p.stock_total>0?' · '+p.stock_total:''}</span></div><h3 class="line-clamp-2 min-h-12 text-lg font-black">${esc(p.name)}</h3><p class="mt-1 text-sm text-slate-500">${esc(p.category)} • Rilis ${esc(p.release_year)}</p><p class="mt-2 min-h-5 text-xs font-bold text-slate-400">${esc(variantLine || 'Varian tersedia')}</p><div class="mt-3 flex items-end justify-between gap-3"><div><p class="text-xs font-bold text-slate-400">Mulai dari</p><p class="text-xl font-black">${rupiah(p.price)}</p></div><div class="text-right text-xs font-black text-amber-500"><i class="fa-solid fa-star"></i> ${p.rating||'0.0'} <span class="text-slate-400">(${p.review_count||0})</span></div></div><div class="mt-4 grid grid-cols-[1fr_auto] gap-2"><button class="add-cart rounded-2xl bg-slate-950 px-4 py-3 text-sm font-black text-white disabled:bg-slate-300" data-variant="${idOfVariant(v)}" ${p.stock_total<=0?'disabled':''}>Tambah</button><button class="toggle-wish rounded-2xl border border-slate-200 px-4 py-3 ${liked?'bg-rose-50 text-rose-600':'bg-white text-slate-600'}" data-variant="${idOfVariant(v)}" aria-label="Wishlist"><i class="fa-${liked?'solid':'regular'} fa-heart"></i></button></div></div></article>`;
}

function filteredProduk(){
  let rows=[...S.products]; const q=S.search.trim().toLowerCase();
  if(q) rows=rows.filter(p=>[p.name,p.brand,p.category,p.release_year,variantsOf(idOfProduct(p)).map(v=>`${v.ram} ${v.storage} ${v.color}`).join(' ')].join(' ').toLowerCase().includes(q));
  rows=rows.filter(p=>S.filters.brands.includes(p.brand) && S.filters.categories.includes(p.category));
  rows=rows.filter(p=>Number(p.price)>=S.filters.minPrice && Number(p.price)<=S.filters.maxPrice);
  rows=rows.filter(p=>variantsOf(idOfProduct(p)).some(v=>(S.filters.rams||[]).includes(v.ram) && (S.filters.storages||[]).includes(v.storage)));
  if(S.filters.stockOnly) rows=rows.filter(p=>Number(p.stock_total)>0);
  if(S.sort==='price_asc') rows.sort((a,b)=>a.price-b.price); else if(S.sort==='price_desc') rows.sort((a,b)=>b.price-a.price); else if(S.sort==='newest') rows.sort((a,b)=>b.release_year-a.release_year || b.price-a.price); else if(S.sort==='stock') rows.sort((a,b)=>b.stock_total-a.stock_total); else rows.sort((a,b)=>b.rating-a.rating || b.stock_total-a.stock_total);
  return rows;
}
function catalogPage(){
  const rows=filteredProduk();
  const activeFilters = [S.search?`Cari: ${S.search}`:null, S.filters.stockOnly?'Stok tersedia':null, `${S.filters.brands.length}/${S.brands.length} brand`, `${S.filters.rams.length}/${S.ramOptions.length} RAM`, `${S.filters.storages.length}/${S.storageOptions.length} storage`].filter(Boolean);
  return `<section class="mx-auto max-w-7xl px-4 py-10 lg:px-6"><div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between"><div><p class="text-sm font-black uppercase tracking-[.2em] text-slate-400">Belanja</p><h1 class="mt-2 text-4xl font-black">Katalog smartphone</h1><p class="mt-2 text-slate-500">${rows.length} produk cocok dengan filter.</p><div class="mt-3 flex flex-wrap gap-2">${activeFilters.map(x=>`<span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-black text-slate-600">${esc(x)}</span>`).join('')}</div></div><div class="flex flex-wrap gap-2">${S.brands.map(b=>`<button class="brand-chip rounded-full px-4 py-2 text-sm font-black ring-1 ring-slate-200 ${S.filters.brands.includes(b.brand_name)?'bg-slate-950 text-white':'bg-white text-slate-600'}" data-brand="${esc(b.brand_name)}">${esc(b.brand_name)}</button>`).join('')}</div></div><div class="mt-6 grid gap-6 lg:grid-cols-[320px_1fr]"><aside class="card h-fit rounded-[2rem] p-5"><label class="block text-sm font-black">Cari produk<input id="catalog-search" value="${esc(S.search)}" class="focus-ring mt-2 w-full rounded-2xl border border-slate-200 px-4 py-3 font-bold" placeholder="iPhone, Samsung, 256GB..."></label><label class="mt-4 block text-sm font-black">Urutkan<select id="catalog-sort" class="focus-ring mt-2 w-full rounded-2xl border border-slate-200 px-4 py-3 font-bold">${option('recommended','Rekomendasi',S.sort)}${option('newest','Terbaru',S.sort)}${option('price_asc','Harga termurah',S.sort)}${option('price_desc','Harga tertinggi',S.sort)}${option('stock','Stok terbanyak',S.sort)}</select></label><div class="mt-5"><p class="text-sm font-black">Kategori</p><div class="mt-2 space-y-2">${S.categories.map(c=>checkRow('cat-filter',c.category_name,S.filters.categories.includes(c.category_name))).join('')}</div></div><div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-1"><div><p class="text-sm font-black">RAM</p><div class="mt-2 grid gap-2">${S.ramOptions.map(x=>checkRow('ram-filter',x,(S.filters.rams||[]).includes(x))).join('')}</div></div><div><p class="text-sm font-black">Storage</p><div class="mt-2 grid gap-2">${S.storageOptions.map(x=>checkRow('storage-filter',x,(S.filters.storages||[]).includes(x))).join('')}</div></div></div><div class="mt-5 grid grid-cols-2 gap-3"><label class="text-sm font-black">Min<input id="filter-min" type="number" value="${S.filters.minPrice}" class="focus-ring mt-2 w-full rounded-2xl border border-slate-200 px-3 py-3 font-bold"></label><label class="text-sm font-black">Max<input id="filter-max" type="number" value="${S.filters.maxPrice}" class="focus-ring mt-2 w-full rounded-2xl border border-slate-200 px-3 py-3 font-bold"></label></div><label class="mt-4 flex items-center gap-2 text-sm font-black"><input id="stock-only" type="checkbox" ${S.filters.stockOnly?'checked':''}> Stok tersedia saja</label><button id="reset-filter" class="mt-5 w-full rounded-2xl bg-slate-100 px-4 py-3 font-black text-slate-700">Reset filter</button></aside><div>${rows.length?`<div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3">${rows.map(productCard).join('')}</div>`:emptyState('Produk tidak ditemukan','Filter terlalu sempit. Reset filter atau cari kata kunci lain.','catalog')}</div></div></section>`;
}
function option(val,label,current){ return `<option value="${val}" ${val===current?'selected':''}>${label}</option>`; }
function checkRow(cls,val,checked){ return `<label class="flex items-center gap-2 rounded-2xl bg-slate-50 px-3 py-2 text-sm font-bold text-slate-600"><input class="${cls}" type="checkbox" value="${esc(val)}" ${checked?'checked':''}> ${esc(val)}</label>`; }

function detailPage(){
  const p=findProduct(S.currentProductId) || S.products[0]; if(!p) return errorBox('Produk tidak ditemukan','Katalog belum memiliki produk aktif.');
  const pid=idOfProduct(p); const vars=variantsOf(pid); const v=selectedVariant(pid)||{}; const sp=specOf(pid); const liked=wishVariantIds().has(Number(v.variant_id)); const meta=stockMeta(v.stock);
  const similar=S.products.filter(x=>idOfProduct(x)!==pid && (x.brand===p.brand || x.category===p.category)).slice(0,4);
  const boxItems=['Unit smartphone','Kabel data USB-C','Panduan singkat','Kartu garansi resmi'];
  return `<section class="mx-auto max-w-7xl px-4 py-10 lg:px-6"><button data-page="catalog" class="nav-link mb-5 rounded-2xl bg-white px-4 py-2 font-black ring-1 ring-slate-200"><i class="fa-solid fa-arrow-left mr-2"></i>Katalog</button><div class="grid gap-7 lg:grid-cols-[.92fr_1.08fr]"><div class="card rounded-[2.5rem] p-5"><img src="${imgOf(p)}" alt="${esc(p.name)}" class="h-[520px] w-full rounded-[2rem] bg-slate-50 object-contain"><div class="mt-4 grid grid-cols-3 gap-3 text-center text-xs font-black text-slate-500"><span class="rounded-2xl bg-slate-50 p-3"><i class="fa-solid fa-shield-halved block text-slate-950"></i>Garansi resmi</span><span class="rounded-2xl bg-slate-50 p-3"><i class="fa-solid fa-truck-fast block text-slate-950"></i>Estimasi jelas</span><span class="rounded-2xl bg-slate-50 p-3"><i class="fa-solid fa-rotate-left block text-slate-950"></i>Cek varian</span></div></div><div class="card rounded-[2.5rem] p-7"><div class="flex flex-wrap gap-2"><span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-black uppercase text-slate-600">${esc(p.brand)}</span><span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-black uppercase text-blue-600">${esc(p.category)}</span><span class="rounded-full ${meta.cls} px-3 py-1 text-xs font-black">${meta.label} · stok ${Number(v.stock||0)}</span></div><h1 class="mt-4 text-4xl font-black tracking-tight md:text-5xl">${esc(p.name)}</h1><p class="mt-3 text-slate-500">${esc(p.tagline)} • Rilis ${esc(p.release_year)}. Cocok untuk produktivitas harian, multitasking, foto, video, dan hiburan.</p><div class="mt-5 flex flex-wrap items-end gap-4"><p class="text-4xl font-black">${rupiah(v.price||p.price)}</p><p class="pb-1 text-sm font-black text-amber-500"><i class="fa-solid fa-star"></i> ${p.rating||'0.0'} dari ${p.review_count||0} review</p></div><div class="mt-6"><p class="mb-2 text-sm font-black">Pilih warna, RAM, dan storage</p><div class="grid gap-2 sm:grid-cols-2">${vars.map(x=>`<button class="variant-btn rounded-2xl border px-4 py-3 text-left ${idOfVariant(x)===idOfVariant(v)?'border-slate-950 bg-slate-950 text-white':'border-slate-200 bg-white text-slate-700'}" data-product="${pid}" data-variant="${idOfVariant(x)}"><b class="block">${esc(x.color)}</b><small>${esc(x.ram)} / ${esc(x.storage)} • ${rupiah(x.price)} • stok ${x.stock}</small></button>`).join('')}</div></div><div class="mt-6 grid gap-3 sm:grid-cols-[150px_1fr_auto]"><label class="text-sm font-black">Qty<input id="detail-qty" type="number" min="1" max="${v.stock||1}" value="${S.selectedQty}" class="focus-ring mt-2 w-full rounded-2xl border border-slate-200 px-4 py-3 font-bold"></label><button class="add-cart mt-6 rounded-2xl bg-slate-950 px-5 py-4 font-black text-white disabled:bg-slate-300" data-variant="${idOfVariant(v)}" ${!v.stock?'disabled':''}>Masukkan keranjang</button><button class="toggle-wish mt-6 rounded-2xl border border-slate-200 px-5 py-4 ${liked?'bg-rose-50 text-rose-600':'bg-white text-slate-600'}" data-variant="${idOfVariant(v)}"><i class="fa-${liked?'solid':'regular'} fa-heart"></i></button></div><div class="mt-7 grid gap-3 sm:grid-cols-2">${specCard('Display',sp.display_inch,'fa-tv')}${specCard('Chipset',sp.chipset,'fa-microchip')}${specCard('Battery',sp.battery,'fa-battery-full')}${specCard('Camera',sp.camera,'fa-camera')}</div></div></div><div class="mt-7 grid gap-6 lg:grid-cols-3"><div class="card rounded-[2rem] p-6"><h2 class="text-xl font-black">Isi dalam box</h2><div class="mt-4 space-y-2">${boxItems.map(x=>`<p class="rounded-2xl bg-slate-50 px-4 py-3 text-sm font-bold"><i class="fa-solid fa-check mr-2 text-emerald-600"></i>${esc(x)}</p>`).join('')}</div></div><div class="card rounded-[2rem] p-6"><h2 class="text-xl font-black">Layanan pembelian</h2><p class="mt-3 text-sm leading-6 text-slate-500">Produk dikemas aman, stok mengikuti varian yang dipilih, dan status pesanan dapat dipantau dari halaman riwayat pesanan.</p><div class="mt-4 grid gap-2 text-sm font-bold text-slate-600"><span><i class="fa-solid fa-shield-halved mr-2"></i>Garansi resmi toko</span><span><i class="fa-solid fa-clock mr-2"></i>Estimasi pengiriman 2–5 hari</span><span><i class="fa-solid fa-credit-card mr-2"></i>Transfer, e-wallet, kartu, atau COD</span></div></div><div class="card rounded-[2rem] p-6"><h2 class="text-xl font-black">Rekomendasi serupa</h2><div class="mt-4 space-y-3">${similar.map(x=>`<button class="detail-go flex w-full items-center gap-3 rounded-2xl bg-slate-50 p-3 text-left" data-product="${idOfProduct(x)}"><img src="${imgOf(x)}" class="h-12 w-12 rounded-xl bg-white object-contain"><span><b class="block text-sm">${esc(x.name)}</b><small class="text-slate-500">${rupiah(x.price)}</small></span></button>`).join('')||'<p class="text-sm text-slate-500">Belum ada rekomendasi.</p>'}</div></div></div></section>`;
}
function specCard(label,value,icon){ return `<div class="rounded-3xl bg-slate-50 p-4"><p class="text-xs font-black uppercase tracking-wide text-slate-400"><i class="fa-solid ${icon} mr-2"></i>${label}</p><p class="mt-1 font-black">${esc(value||'-')}</p></div>`; }

function cartPage(){
  if(!S.currentUser) return gatePage('Login diperlukan','Masuk ke akun pelanggan untuk melihat dan mengelola keranjang belanja.','login');
  const subtotal=S.cartItems.reduce((a,b)=>a+Number(b.subtotal||0),0); const shipping=S.cartItems.length?150000:0; const total=subtotal+shipping;
  return `<section class="mx-auto max-w-7xl px-4 py-10 lg:px-6"><div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between"><div><p class="text-sm font-black uppercase tracking-[.2em] text-slate-400">Cart</p><h1 class="mt-2 text-4xl font-black">Keranjang belanja</h1><p class="mt-2 text-slate-500">${S.cartItems.length} item di keranjang.</p></div><button id="refresh-cart" class="rounded-2xl bg-white px-5 py-3 font-black ring-1 ring-slate-200">Refresh</button></div><div class="mt-6 grid gap-6 lg:grid-cols-[1fr_360px]"><div class="space-y-4">${S.cartItems.length?S.cartItems.map(cartRow).join(''):emptyState('Keranjang kosong','Tambahkan produk dari catalog. Pilih produk dan tambahkan ke keranjang.','catalog')}</div><aside class="card h-fit rounded-[2rem] p-6"><h2 class="text-2xl font-black">Ringkasan</h2><div class="mt-5 space-y-3 text-sm"><div class="flex justify-between"><span class="text-slate-500">Subtotal</span><b>${rupiah(subtotal)}</b></div><div class="flex justify-between"><span class="text-slate-500">Estimasi ongkir</span><b>${rupiah(shipping)}</b></div><div class="border-t border-slate-200 pt-3 flex justify-between text-lg"><span class="font-black">Total</span><b>${rupiah(total)}</b></div></div><button data-page="checkout" class="nav-link mt-6 w-full rounded-2xl bg-slate-950 px-5 py-4 font-black text-white disabled:bg-slate-300" ${S.cartItems.length?'':'disabled'}>Checkout</button><button id="clear-cart" class="mt-3 w-full rounded-2xl bg-slate-100 px-5 py-3 font-black text-slate-600" ${S.cartItems.length?'':'disabled'}>Kosongkan</button></aside></div></section>`;
}
function cartRow(item){ return `<div class="card rounded-[2rem] p-4"><div class="grid gap-4 sm:grid-cols-[140px_1fr_auto]"><img src="${esc(item.image_url)}" class="h-36 w-full rounded-3xl bg-slate-50 object-contain" alt="${esc(item.product_name)}"><div><h3 class="text-xl font-black">${esc(item.product_name)}</h3><p class="mt-1 text-sm text-slate-500">${esc(item.brand_name)} • ${esc(item.color)} • ${esc(item.ram)} / ${esc(item.storage)}</p><p class="mt-3 text-lg font-black">${rupiah(item.price)}</p><p class="mt-1 text-xs font-bold ${item.stock>=item.quantity?'text-emerald-600':'text-rose-600'}">Stok tersedia: ${item.stock}</p></div><div class="flex flex-row items-center gap-2 sm:flex-col sm:items-end"><input class="cart-qty focus-ring w-24 rounded-2xl border border-slate-200 px-3 py-3 font-black" type="number" min="1" max="${item.stock}" value="${item.quantity}" data-cart="${item.cart_id}"><button class="remove-cart rounded-2xl bg-rose-50 px-4 py-3 font-black text-rose-600" data-cart="${item.cart_id}"><i class="fa-solid fa-trash"></i></button><b>${rupiah(item.subtotal)}</b></div></div></div>`; }

function checkoutPage(){
  if(!S.currentUser) return gatePage('Login diperlukan','Masuk ke akun pelanggan untuk menyelesaikan checkout.', 'login');
  if(!S.cartItems.length) return `<section class="mx-auto max-w-7xl px-4 py-10 lg:px-6">${emptyState('Keranjang kosong','Tidak ada item untuk checkout.','catalog')}</section>`;
  const u=S.currentUser; const subtotal=S.cartItems.reduce((a,b)=>a+Number(b.subtotal||0),0); const shipping=150000; const total=subtotal+shipping; const addr=S.checkout.address || [u.address,u.city,u.province].filter(Boolean).join(', ');
  return `<section class="mx-auto max-w-7xl px-4 py-10 lg:px-6"><h1 class="text-4xl font-black">Checkout</h1><p class="mt-2 text-slate-500">Lengkapi data penerima, pilih metode pembayaran, lalu buat pesanan.</p><form id="checkout-form" class="mt-6 grid gap-6 lg:grid-cols-[1fr_380px]"><div class="space-y-5"><div class="card rounded-[2rem] p-6"><h2 class="text-2xl font-black">Data penerima</h2><div class="mt-4 grid gap-3 sm:grid-cols-2">${input('co-name','Nama penerima',S.checkout.name||u.full_name||u.name)}${input('co-phone','No. HP',S.checkout.phone||u.phone||'')}</div><label class="mt-3 block text-sm font-black">Alamat pengiriman<textarea id="co-address" class="focus-ring mt-2 min-h-28 w-full rounded-2xl border border-slate-200 px-4 py-3 font-bold">${esc(addr)}</textarea></label></div><div class="card rounded-[2rem] p-6"><h2 class="text-2xl font-black">Metode pembayaran</h2><div class="mt-4 grid gap-3 sm:grid-cols-2">${paymentOption('transfer_bank','Transfer bank','fa-building-columns')}${paymentOption('ewallet','E-Wallet','fa-wallet')}${paymentOption('credit_card','Kartu kredit','fa-credit-card')}${paymentOption('cod','COD','fa-truck')}</div><div id="payment-extra" class="mt-4">${paymentExtra()}</div></div></div><aside class="card h-fit rounded-[2rem] p-6"><h2 class="text-2xl font-black">Review order</h2><div class="mt-4 max-h-72 space-y-3 overflow-y-auto pr-1 scroll-clean">${S.cartItems.map(i=>`<div class="flex gap-3 rounded-2xl bg-slate-50 p-3"><img src="${esc(i.image_url)}" class="h-14 w-14 rounded-xl object-contain"><div class="min-w-0 flex-1"><b class="block truncate text-sm">${esc(i.product_name)}</b><small class="text-slate-500">${i.quantity} × ${rupiah(i.price)}</small></div><b class="text-sm">${rupiah(i.subtotal)}</b></div>`).join('')}</div><div class="mt-5 space-y-3 text-sm"><div class="flex justify-between"><span class="text-slate-500">Subtotal</span><b>${rupiah(subtotal)}</b></div><div class="flex justify-between"><span class="text-slate-500">Ongkir</span><b>${rupiah(shipping)}</b></div><div class="border-t border-slate-200 pt-3 flex justify-between text-lg"><span class="font-black">Total</span><b>${rupiah(total)}</b></div></div><button class="mt-6 w-full rounded-2xl bg-slate-950 px-5 py-4 font-black text-white">Buat pesanan</button></aside></form></section>`;
}
function paymentOption(value,label,icon){ return `<label class="payment-option rounded-2xl border ${S.checkout.paymentMethod===value?'border-slate-950 bg-slate-950 text-white':'border-slate-200 bg-white text-slate-700'} p-4 font-black"><input type="radio" name="payment" value="${value}" class="hidden" ${S.checkout.paymentMethod===value?'checked':''}><i class="fa-solid ${icon} mr-2"></i>${label}</label>`; }
function paymentExtra(){
  const m=S.checkout.paymentMethod;
  if(m==='transfer_bank') return `<label class="text-sm font-black">Bank<select id="co-bank" class="focus-ring mt-2 w-full rounded-2xl border border-slate-200 px-4 py-3 font-bold"><option>BCA</option><option>Mandiri</option><option>BRI</option><option>BNI</option></select></label>`;
  if(m==='ewallet') return `<label class="text-sm font-black">Provider<select id="co-ewallet" class="focus-ring mt-2 w-full rounded-2xl border border-slate-200 px-4 py-3 font-bold"><option>GoPay</option><option>OVO</option><option>DANA</option><option>BelanjaeePay</option></select></label>`;
  if(m==='credit_card') return `<div class="grid gap-3 sm:grid-cols-2">${input('co-card-name','Nama kartu',S.currentUser?.full_name||'')}${input('co-card-number','Nomor kartu','4111 1111 1111 1111')}</div>`;
  return `<p class="rounded-2xl bg-amber-50 p-4 text-sm font-bold text-amber-700">Bayar tunai saat pesanan diterima oleh pelanggan.</p>`;
}

function wishlistPage(){
  if(!S.currentUser) return gatePage('Login diperlukan','Masuk ke akun pelanggan untuk menyimpan produk favorit.', 'login');
  const ids=new Set(S.wishlist.map(w=>w.product_id)); const products=S.products.filter(p=>ids.has(idOfProduct(p)));
  return `<section class="mx-auto max-w-7xl px-4 py-10 lg:px-6"><div class="flex items-end justify-between gap-4"><div><p class="text-sm font-black uppercase tracking-[.2em] text-slate-400">Wishlist</p><h1 class="mt-2 text-4xl font-black">Produk tersimpan</h1><p class="mt-2 text-slate-500">${S.wishlist.length} item tersimpan.</p></div><button id="refresh-wishlist" class="rounded-2xl bg-white px-5 py-3 font-black ring-1 ring-slate-200">Refresh</button></div><div class="mt-6">${products.length?`<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">${products.map(productCard).join('')}</div>`:emptyState('Wishlist kosong','Klik ikon hati pada produk untuk menyimpannya di wishlist.','catalog')}</div></section>`;
}

function historyPage(){
  if(!S.currentUser) return gatePage('Login diperlukan','Masuk ke akun pelanggan untuk melihat riwayat pesanan.', 'login');
  return `<section class="mx-auto max-w-7xl px-4 py-10 lg:px-6"><div class="flex items-end justify-between"><div><p class="text-sm font-black uppercase tracking-[.2em] text-slate-400">Orders</p><h1 class="mt-2 text-4xl font-black">Riwayat pesanan</h1><p class="mt-2 text-slate-500">Pantau status pesanan dan cetak invoice dari sini.</p></div><button id="load-orders" class="rounded-2xl bg-slate-950 px-5 py-3 font-black text-white">Refresh</button></div><div id="orders-box" class="mt-6">${S.orders.length?ordersHTML(S.orders):loading('Memuat riwayat','Mengambil daftar pesanan Anda.')}</div></section>`;
}
function ordersHTML(orders){ if(!orders.length) return emptyState('Belum ada order','Checkout produk untuk membuat pesanan baru.','catalog'); return `<div class="space-y-5">${orders.map(o=>{const inf=statusInfo(o.status); return `<div class="card rounded-[2rem] p-5"><div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between"><div><p class="text-sm font-black text-slate-400">ORD-${o.order_id} • ${esc(o.order_date)}</p><h3 class="mt-1 text-xl font-black">${rupiah(o.total_amount)}</h3><p class="mt-1 text-sm text-slate-500">${esc(o.shipping_address)}</p></div><div class="flex flex-wrap gap-2"><span class="rounded-full ${inf.cls} px-3 py-1 text-xs font-black">${esc(inf.label)}</span><span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-black text-slate-600">${esc(o.payment_method)} / ${esc(o.payment_status)}</span><button class="open-invoice rounded-full bg-slate-950 px-3 py-1 text-xs font-black text-white" data-order="${o.order_id}">Invoice</button></div></div><div class="mt-4">${statusTimeline(o.status)}</div><div class="mt-4 grid gap-2 md:grid-cols-2">${(o.items||[]).map(i=>`<div class="flex gap-3 rounded-2xl bg-slate-50 p-3"><img src="${esc(i.image_url)}" class="h-14 w-14 rounded-xl object-contain"><div><b class="text-sm">${esc(i.product_name)}</b><p class="text-xs text-slate-500">${esc(i.color)} • ${i.quantity} × ${rupiah(i.unit_price)}</p></div></div>`).join('')}</div></div>`}).join('')}</div>`; }
function invoicePage(){
  if(!S.currentUser) return gatePage('Login diperlukan','Masuk ke akun pelanggan untuk melihat invoice.', 'login');
  const order=S.orders.find(o=>Number(o.order_id)===Number(S.invoiceOrderId)) || S.orders[0];
  if(!order) return `<section class="mx-auto max-w-7xl px-4 py-10 lg:px-6">${loading('Memuat invoice','Ambil riwayat pesanan terlebih dahulu.')}</section>`;
  const subtotal=(order.items||[]).reduce((a,b)=>a+Number(b.subtotal||Number(b.quantity||0)*Number(b.unit_price||0)),0); const shipping=Math.max(0,Number(order.total_amount||0)-subtotal); const inf=statusInfo(order.status);
  return `<section class="mx-auto max-w-5xl px-4 py-10 lg:px-6"><div class="no-print mb-5 flex flex-wrap justify-between gap-3"><button data-page="history" class="nav-link rounded-2xl bg-white px-4 py-3 font-black ring-1 ring-slate-200"><i class="fa-solid fa-arrow-left mr-2"></i>Riwayat pesanan</button><button id="print-invoice" class="rounded-2xl bg-slate-950 px-5 py-3 font-black text-white"><i class="fa-solid fa-print mr-2"></i>Cetak invoice</button></div><div class="invoice-print card rounded-[2.5rem] p-8"><div class="flex flex-col gap-4 border-b border-slate-200 pb-6 md:flex-row md:items-start md:justify-between"><div><p class="text-xs font-black uppercase tracking-[.2em] text-slate-400">Invoice</p><h1 class="mt-2 text-4xl font-black">ORD-${order.order_id}</h1><p class="mt-2 text-sm text-slate-500">Tanggal: ${esc(order.order_date)}</p></div><div class="text-left md:text-right"><b class="block text-2xl">ephone</b><p class="mt-1 text-sm text-slate-500">Toko Smartphone Online<br>support@ephone.id</p><span class="mt-3 inline-flex rounded-full ${inf.cls} px-3 py-1 text-xs font-black">${esc(inf.label)}</span></div></div><div class="mt-6 grid gap-5 md:grid-cols-2"><div class="rounded-3xl bg-slate-50 p-5"><p class="text-xs font-black uppercase tracking-wide text-slate-400">Ditagihkan kepada</p><b class="mt-2 block">${esc(order.customer_name||S.currentUser.full_name||S.currentUser.name)}</b><p class="mt-1 text-sm text-slate-500">${esc(S.currentUser.email||order.customer_email||'')}</p><p class="mt-2 text-sm text-slate-500">${esc(order.shipping_address)}</p></div><div class="rounded-3xl bg-slate-50 p-5"><p class="text-xs font-black uppercase tracking-wide text-slate-400">Pembayaran</p><b class="mt-2 block">${esc(order.payment_method)} / ${esc(order.payment_status)}</b><p class="mt-2 text-sm text-slate-500">Status pesanan: ${esc(inf.label)}</p><p class="mt-2 text-sm text-slate-500">${esc(inf.desc)}</p></div></div><div class="mt-6 overflow-x-auto"><table class="min-w-full text-sm"><thead><tr class="border-b text-left text-xs uppercase tracking-wide text-slate-400"><th class="py-3 pr-4">Produk</th><th class="py-3 pr-4">Varian</th><th class="py-3 pr-4">Qty</th><th class="py-3 pr-4">Harga</th><th class="py-3 text-right">Subtotal</th></tr></thead><tbody>${(order.items||[]).map(i=>`<tr class="border-b border-slate-100"><td class="py-4 pr-4 font-black">${esc(i.product_name)}</td><td class="py-4 pr-4 text-slate-500">${esc(i.color)} • ${esc(i.ram)}/${esc(i.storage)}</td><td class="py-4 pr-4">${i.quantity}</td><td class="py-4 pr-4">${rupiah(i.unit_price)}</td><td class="py-4 text-right font-black">${rupiah(i.subtotal)}</td></tr>`).join('')}</tbody></table></div><div class="mt-6 ml-auto max-w-sm space-y-3 text-sm"><div class="flex justify-between"><span class="text-slate-500">Subtotal</span><b>${rupiah(subtotal)}</b></div><div class="flex justify-between"><span class="text-slate-500">Ongkir</span><b>${rupiah(shipping)}</b></div><div class="border-t border-slate-200 pt-3 flex justify-between text-xl"><span class="font-black">Total</span><b>${rupiah(order.total_amount)}</b></div></div></div></section>`;
}

function loginPage(role){
  const isAdmin=role==='admin';
  const demo=isAdmin?{email:'admin@ephone.id',password:'admin123'}:{email:'abhista.dyfan@gmail.com',password:'abhista123'};
  return `<section class="mx-auto grid min-h-[70vh] max-w-7xl items-center px-4 py-10 lg:px-6"><div class="mx-auto grid w-full max-w-5xl overflow-hidden rounded-[2.5rem] bg-white shadow-2xl shadow-slate-200 ring-1 ring-slate-200 lg:grid-cols-[.9fr_1.1fr]"><div class="dark-card p-8 text-white"><p class="text-xs font-black uppercase tracking-[.22em] text-slate-400">${isAdmin?'Area admin':'Akun pelanggan'}</p><h1 class="mt-4 text-4xl font-black">Masuk ke ephone</h1><p class="mt-3 text-slate-300">Kelola ${isAdmin?'produk, stok, pesanan, dan laporan toko':'keranjang, wishlist, profil, dan riwayat pesanan'} dengan akun yang sudah terdaftar.</p><div class="mt-8 grid gap-3"><div class="rounded-3xl bg-white/10 p-4"><i class="fa-solid fa-lock mr-2"></i><b>Keamanan akun</b><p class="mt-1 text-sm text-slate-300">Akses dipisahkan antara pelanggan dan admin.</p></div><div class="rounded-3xl bg-white/10 p-4"><i class="fa-solid fa-bolt mr-2"></i><b>Transaksi cepat</b><p class="mt-1 text-sm text-slate-300">Keranjang, checkout, dan pesanan tersimpan setelah login.</p></div></div></div><form id="login-form" class="p-8"><h2 class="text-2xl font-black">${isAdmin?'Login Admin':'Login Pelanggan'}</h2><p class="mt-2 text-sm text-slate-500">Gunakan akun yang tersedia pada data aplikasi.</p><label class="mt-6 block text-sm font-black">Email<input id="login-email" type="email" value="${demo.email}" class="focus-ring mt-2 w-full rounded-2xl border border-slate-200 px-4 py-4 font-bold"></label><label class="mt-4 block text-sm font-black">Password<input id="login-password" type="password" value="${demo.password}" class="focus-ring mt-2 w-full rounded-2xl border border-slate-200 px-4 py-4 font-bold"></label><button class="mt-6 w-full rounded-2xl bg-slate-950 px-5 py-4 font-black text-white">Masuk</button></form></div></section>`;
}

function gatePage(title,msg,page){ return `<section class="mx-auto max-w-7xl px-4 py-16 lg:px-6"><div class="card mx-auto max-w-2xl rounded-[2rem] p-8 text-center"><div class="mx-auto grid h-14 w-14 place-items-center rounded-2xl bg-slate-950 text-white"><i class="fa-solid fa-lock"></i></div><h1 class="mt-5 text-3xl font-black">${esc(title)}</h1><p class="mt-2 text-slate-500">${esc(msg)}</p><button data-page="${page}" class="nav-link mt-6 rounded-2xl bg-slate-950 px-6 py-4 font-black text-white">Login</button></div></section>`; }

function profilePage(){
  if(!S.currentUser) return gatePage('Login customer dulu','Masuk ke akun pelanggan untuk mengelola profil.', 'login'); const u=S.currentUser;
  return `<section class="mx-auto max-w-4xl px-4 py-10 lg:px-6"><div class="card rounded-[2rem] p-7"><p class="text-sm font-black uppercase tracking-[.2em] text-slate-400">Profil</p><h1 class="mt-2 text-4xl font-black">Data pelanggan</h1><form id="profile-form" class="mt-6 grid gap-4 sm:grid-cols-2">${input('pf-name','Nama lengkap',u.full_name||u.name)}${input('pf-email','Email',u.email,'email')}${input('pf-phone','No. HP',u.phone||'')}${input('pf-city','Kota',u.city||'')}${input('pf-province','Provinsi',u.province||'')}<label class="sm:col-span-2 text-sm font-black">Alamat<textarea id="pf-address" class="focus-ring mt-2 min-h-28 w-full rounded-2xl border border-slate-200 px-4 py-3 font-bold">${esc(u.address||'')}</textarea></label><button class="sm:col-span-2 rounded-2xl bg-slate-950 px-5 py-4 font-black text-white">Simpan perubahan</button></form></div></section>`;
}
function input(id,label,value='',type='text'){ return `<label class="text-sm font-black">${label}<input id="${id}" type="${type}" value="${esc(value)}" class="focus-ring mt-2 w-full rounded-2xl border border-slate-200 px-4 py-3 font-bold"></label>`; }

function adminPage(){
  if(!S.currentAdmin) return gatePage('Login admin diperlukan','Masuk sebagai admin untuk mengelola produk, stok, pesanan, dan laporan toko.', 'login-admin');
  const tabs=[['overview','Ringkasan','fa-chart-pie'],['stock','Stok','fa-boxes-stacked'],['orders','Pesanan','fa-receipt'],['products','Produk','fa-mobile'],['reports','Laporan','fa-chart-line']];
  return `<section class="mx-auto max-w-7xl px-4 py-10 lg:px-6"><div class="dark-card rounded-[2.5rem] p-7 text-white"><div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between"><div><p class="text-sm font-black uppercase tracking-[.2em] text-slate-400">Dashboard Admin</p><h1 class="mt-2 text-4xl font-black">Kelola operasional toko</h1><p class="mt-2 text-slate-300">Pantau stok, kelola produk, ubah status pesanan, dan lihat performa penjualan.</p></div><button id="admin-refresh" class="rounded-2xl bg-white px-5 py-3 font-black text-slate-950">Perbarui data</button></div><div class="mt-6 flex flex-wrap gap-2">${tabs.map(t=>`<button class="admin-tab rounded-2xl px-4 py-3 text-sm font-black ${S.adminTab===t[0]?'bg-white text-slate-950':'bg-white/10 text-white'}" data-tab="${t[0]}"><i class="fa-solid ${t[2]} mr-2"></i>${t[1]}</button>`).join('')}</div></div><div class="mt-6">${adminTabHTML()}</div></section>`;
}
function adminTabHTML(){ if(S.adminTab==='stock') return adminStok(); if(S.adminTab==='orders') return adminOrders(); if(S.adminTab==='products') return adminProduk(); if(S.adminTab==='reports') return adminLaporan(); return adminRingkasan(); }
function adminRingkasan(){
  const lowVars=S.variants.filter(v=>Number(v.stock||0)<=10).sort((a,b)=>a.stock-b.stock); const low=lowVars.length; const stock=S.variants.reduce((a,b)=>a+Number(b.stock||0),0);
  const byBrand=S.brands.map(b=>({name:b.brand_name,total:S.products.filter(p=>p.brand===b.brand_name).length}));
  return `<div class="grid gap-4 md:grid-cols-4">${metricCard('Produk',S.products.length,'fa-mobile-screen-button')}${metricCard('Varian',S.variants.length,'fa-layer-group')}${metricCard('Total stok',stock,'fa-boxes-stacked')}${metricCard('Stok rendah',low,'fa-triangle-exclamation')}</div><div class="mt-6 grid gap-6 lg:grid-cols-[1.05fr_.95fr]"><div class="card rounded-[2rem] p-6"><div class="flex items-start justify-between gap-4"><div><h2 class="text-2xl font-black">Low stock alert</h2><p class="mt-1 text-sm text-slate-500">Varian dengan stok 10 unit ke bawah perlu diprioritaskan untuk restock.</p></div><button class="admin-tab rounded-2xl bg-slate-950 px-4 py-3 text-sm font-black text-white" data-tab="stock">Kelola stok</button></div><div class="mt-4 space-y-2">${lowVars.slice(0,10).map(v=>{const p=findProduct(v.product_id); const meta=stockMeta(v.stock);return `<div class="flex items-center justify-between gap-3 rounded-2xl bg-slate-50 p-3 text-sm"><span class="min-w-0"><b class="block truncate">${esc(p?.name)}</b><p class="text-xs text-slate-500">${esc(v.color)} • ${esc(v.ram)}/${esc(v.storage)}</p></span><span class="rounded-full ${meta.cls} px-3 py-1 text-xs font-black">${v.stock} unit</span></div>`}).join('') || '<p class="rounded-2xl bg-emerald-50 p-4 text-sm font-bold text-emerald-700">Semua stok masih aman.</p>'}</div></div><div class="space-y-6"><div class="card rounded-[2rem] p-6"><h2 class="text-2xl font-black">Komposisi brand</h2><div class="mt-4 grid gap-3">${byBrand.map(b=>`<div class="rounded-2xl bg-slate-50 p-4"><div class="flex justify-between"><b>${esc(b.name)}</b><b>${b.total} produk</b></div><div class="mt-2 h-2 rounded-full bg-slate-200"><div class="h-2 rounded-full bg-slate-950" style="width:${Math.min(100,b.total/Math.max(1,S.products.length)*100)}%"></div></div></div>`).join('')}</div></div><div class="card rounded-[2rem] p-6"><h2 class="text-2xl font-black">Aksi cepat</h2><div class="mt-4 grid gap-3"><button class="admin-tab rounded-2xl bg-slate-100 px-4 py-3 text-left font-black text-slate-700" data-tab="products"><i class="fa-solid fa-plus mr-2"></i>Tambah / edit produk</button><button class="admin-tab rounded-2xl bg-slate-100 px-4 py-3 text-left font-black text-slate-700" data-tab="orders"><i class="fa-solid fa-receipt mr-2"></i>Cek pesanan masuk</button><button class="admin-tab rounded-2xl bg-slate-100 px-4 py-3 text-left font-black text-slate-700" data-tab="reports"><i class="fa-solid fa-chart-line mr-2"></i>Lihat aktivitas terbaru</button></div></div></div></div>`;
}
function adminStok(){
  const totalStock=S.variants.reduce((a,b)=>a+Number(b.stock||0),0);
  const lowStock=S.variants.filter(v=>Number(v.stock||0)<10).length;
  return `<div class="space-y-5"><div class="grid gap-4 md:grid-cols-3">${metricCard('Total stok',totalStock,'fa-boxes-stacked')}${metricCard('Varian aktif',S.variants.length,'fa-layer-group')}${metricCard('Stok rendah',lowStock,'fa-triangle-exclamation')}</div><div class="card rounded-[2rem] p-6"><div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between"><div><h2 class="text-2xl font-black">Manajemen stok varian</h2><p class="mt-1 text-sm text-slate-500">Stok di katalog dihitung dari semua varian produk. Ubah angka lalu klik Simpan.</p></div><input id="admin-stock-search" class="focus-ring rounded-2xl border border-slate-200 px-4 py-3 font-bold" placeholder="Cari produk / varian"></div><div id="admin-stock-box" class="mt-5 overflow-x-auto scroll-clean">${stockTableRows(S.variants)}</div></div></div>`;
}
function stockTableRows(vars){
  if(!vars.length) return '<p class="rounded-2xl bg-slate-50 p-4 text-sm font-bold text-slate-500">Varian tidak ditemukan.</p>';
  return `<table class="min-w-full text-sm"><thead><tr class="border-b text-left text-xs uppercase tracking-wide text-slate-400"><th class="py-3 pr-4">Produk</th><th class="py-3 pr-4">Varian</th><th class="py-3 pr-4">Harga</th><th class="py-3 pr-4">Stok</th><th class="py-3 pr-4">Aksi</th></tr></thead><tbody>${vars.map(v=>{const p=findProduct(v.product_id); const low=Number(v.stock)<10; return `<tr class="border-b border-slate-100"><td class="py-3 pr-4"><div class="flex items-center gap-3"><img src="${imgOf(p)}" class="h-12 w-12 rounded-xl bg-slate-50 object-contain"><span><b>${esc(p?.name)}</b><p class="text-xs text-slate-500">${esc(p?.brand)} • ${esc(p?.category)}</p></span></div></td><td class="py-3 pr-4"><b>${esc(v.color)}</b><p class="text-xs text-slate-500">${esc(v.ram)} / ${esc(v.storage)}</p></td><td class="py-3 pr-4 font-black">${rupiah(v.price)}</td><td class="py-3 pr-4"><input type="number" min="0" class="stock-set-input focus-ring w-28 rounded-xl border ${low?'border-rose-300 bg-rose-50':'border-slate-200'} px-3 py-2 font-black" data-variant-id="${v.variant_id}" value="${v.stock}"><p class="mt-1 text-[11px] font-black ${low?'text-rose-600':'text-slate-400'}">${low?'Stok rendah':'Tersedia'}</p></td><td class="py-3 pr-4"><div class="flex flex-wrap gap-2"><button type="button" class="stock-delta rounded-xl bg-slate-100 px-3 py-2 font-black" data-variant-id="${v.variant_id}" data-delta="-1">-1</button><button type="button" class="stock-delta rounded-xl bg-slate-100 px-3 py-2 font-black" data-variant-id="${v.variant_id}" data-delta="1">+1</button><button type="button" class="stock-set rounded-xl bg-slate-950 px-4 py-2 font-black text-white" data-variant-id="${v.variant_id}">Simpan</button></div></td></tr>`}).join('')}</tbody></table>`;
}
function adminOrders(){ return `<div class="card rounded-[2rem] p-6"><div class="flex items-center justify-between"><h2 class="text-2xl font-black">Manajemen pesanan</h2><button id="load-admin-orders" class="rounded-2xl bg-slate-950 px-5 py-3 font-black text-white">Muat pesanan</button></div><div id="admin-orders-box" class="mt-5">${S.adminOrders.length?adminOrdersHTML(S.adminOrders):'<p class="text-slate-500">Klik Muat pesanan untuk menampilkan daftar pesanan terbaru.</p>'}</div></div>`; }
function adminOrdersHTML(orders){ if(!orders.length) return '<p class="text-slate-500">Belum ada pesanan.</p>'; return `<div class="space-y-3">${orders.map(o=>{const inf=statusInfo(o.status); return `<div class="rounded-3xl bg-slate-50 p-4"><div class="grid gap-3 md:grid-cols-[1fr_auto_auto]"><div><b>ORD-${o.order_id}</b><p class="text-sm text-slate-500">${esc(o.customer_name)} • ${esc(o.order_date)} • ${rupiah(o.total_amount)}</p><p class="mt-1 text-xs text-slate-400">${esc((o.items||[]).map(i=>i.product_name).join(', '))}</p><span class="mt-2 inline-flex rounded-full ${inf.cls} px-3 py-1 text-xs font-black">${esc(inf.label)}</span></div><select class="order-status rounded-2xl border border-slate-200 bg-white px-3 py-2 font-black" data-order="${o.order_id}">${['pending','confirmed','shipped','delivered','cancelled'].map(s=>`<option value="${s}" ${o.status===s?'selected':''}>${statusInfo(s).label}</option>`).join('')}</select><span class="rounded-full bg-white px-3 py-2 text-xs font-black text-slate-500">${esc(o.payment_method)} / ${esc(o.payment_status)}</span></div></div>`}).join('')}</div>`; }
function adminProduk(){
  const selected=findProduct(S.justAddedProductId) || S.products[0] || {};
  const selectedId=idOfProduct(selected);
  const selectedVariants=variantsOf(selectedId);
  const activeVariant=selectedVariants[0] || {};
  const recent=[...S.products].sort((a,b)=>Number(String(idOfProduct(b)).replace(/\D/g,''))-Number(String(idOfProduct(a)).replace(/\D/g,''))).slice(0,12);
  const options=S.products.map(x=>`<option value="${idOfProduct(x)}" ${idOfProduct(x)===selectedId?'selected':''}>${esc(x.name)} — ${esc(x.brand)}</option>`).join('');
  const variantOptions=selectedVariants.map(v=>`<option value="${v.variant_id}">${esc(v.color)} • ${esc(v.ram)}/${esc(v.storage)} • Stok ${v.stock}</option>`).join('');
  return `<div class="grid gap-6 xl:grid-cols-[1fr_.9fr]"><div class="space-y-6"><form id="add-product-form" class="card rounded-[2rem] p-6"><div class="flex items-start justify-between gap-4"><div><h2 class="text-2xl font-black">Tambah produk</h2><p class="mt-1 text-sm text-slate-500">Produk baru langsung masuk katalog. Stok awal disimpan di varian pertama.</p></div><span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-black text-emerald-700">Aktif setelah disimpan</span></div><div class="mt-5 grid gap-3 sm:grid-cols-2">${input('new-name','Nama produk','Samsung Galaxy A Series')}${select('new-brand','Brand',S.brands.map(b=>b.brand_name))}${select('new-cat','Kategori',S.categories.map(c=>c.category_name))}${input('new-year','Tahun rilis','2026','number')}${input('new-base','Harga dasar','6999000','number')}${input('new-color','Warna','Graphite')}${input('new-ram','RAM','8GB')}${input('new-storage','Storage','256GB')}${input('new-price','Harga varian','7299000','number')}${input('new-stock','Stok awal','25','number')}${input('new-display','Display','6.7 inch AMOLED')}${input('new-chipset','Chipset','Snapdragon / Exynos')}${input('new-battery','Baterai','5000 mAh')}${input('new-camera','Kamera','50MP + 12MP')}</div><button class="mt-5 rounded-2xl bg-slate-950 px-6 py-4 font-black text-white">Tambah produk</button></form><form id="edit-product-form" class="card rounded-[2rem] p-6"><h2 class="text-2xl font-black">Edit produk dan stok</h2><p class="mt-1 text-sm text-slate-500">Pilih produk, edit info utama, lalu update varian termasuk stok.</p><label class="mt-5 block text-sm font-black">Pilih produk<select id="edit-product-select" class="focus-ring mt-2 w-full rounded-2xl border border-slate-200 px-4 py-3 font-bold">${options}</select></label><div class="mt-4 grid gap-3 sm:grid-cols-2">${input('edit-name','Nama produk',selected?.name||'')}${select('edit-brand','Brand',S.brands.map(b=>b.brand_name))}${select('edit-cat','Kategori',S.categories.map(c=>c.category_name))}${input('edit-year','Tahun rilis',selected?.release_year||2026,'number')}${input('edit-base','Harga dasar',selected?.base_price||0,'number')}</div><div class="mt-6 rounded-[1.5rem] bg-slate-50 p-4"><div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between"><div><h3 class="font-black">Varian dan stok</h3><p class="text-sm text-slate-500">Stok yang tampil di katalog berasal dari bagian ini.</p></div><span class="rounded-full bg-white px-3 py-1 text-xs font-black text-slate-500">Total stok produk: ${Number(selected?.stock_total||0)}</span></div><label class="mt-4 block text-sm font-black">Pilih varian<select id="edit-variant-select" class="focus-ring mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 font-bold">${variantOptions||'<option value="">Belum ada varian</option>'}</select></label><div class="mt-4 grid gap-3 sm:grid-cols-2">${input('edit-color','Warna',activeVariant.color||'Black')}${input('edit-ram','RAM',activeVariant.ram||'8GB')}${input('edit-storage','Storage',activeVariant.storage||'128GB')}${input('edit-price','Harga varian',activeVariant.price||selected?.base_price||0,'number')}${input('edit-stock','Stok varian',activeVariant.stock??0,'number')}</div><button type="button" id="save-variant" class="mt-4 rounded-2xl bg-blue-600 px-5 py-3 font-black text-white">Simpan stok/varian</button></div><div class="mt-5 flex flex-wrap gap-3"><button class="rounded-2xl bg-slate-950 px-6 py-4 font-black text-white">Simpan info produk</button><button type="button" id="delete-product" class="rounded-2xl bg-rose-50 px-6 py-4 font-black text-rose-600">Hapus produk</button></div></form></div><div class="card rounded-[2rem] p-6"><div class="flex items-start justify-between gap-4"><div><h2 class="text-2xl font-black">Produk aktif</h2><p class="mt-1 text-sm text-slate-500">Klik produk untuk edit info dan stoknya.</p></div><button id="go-catalog-from-admin" type="button" class="rounded-2xl bg-white px-4 py-3 text-sm font-black ring-1 ring-slate-200">Buka katalog</button></div><div class="mt-5 space-y-3">${recent.map(x=>`<button type="button" class="admin-product-row flex w-full items-center gap-4 rounded-3xl border ${idOfProduct(x)===S.justAddedProductId?'border-emerald-300 bg-emerald-50':'border-slate-100 bg-slate-50'} p-3 text-left hover:border-slate-300" data-product="${idOfProduct(x)}"><img src="${imgOf(x)}" class="h-16 w-16 rounded-2xl bg-white object-contain"><span class="min-w-0 flex-1"><b class="block truncate text-sm">${esc(x.name)}</b><small class="text-slate-500">${esc(x.brand)} • ${esc(x.category)} • ${rupiah(x.price)}</small></span><span class="rounded-full ${Number(x.stock_total)>0?'bg-white text-slate-600':'bg-rose-50 text-rose-600'} px-3 py-1 text-xs font-black">Stok ${x.stock_total}</span></button>`).join('')}</div><p class="mt-4 rounded-2xl bg-blue-50 p-4 text-sm font-bold text-blue-700">Sekarang stok bisa diubah dari tab Stok atau dari form Edit produk dan stok.</p></div></div>`;
}

function adminLaporan(){ return `<div class="card rounded-[2rem] p-6"><div class="flex items-center justify-between"><h2 class="text-2xl font-black">Laporan penjualan</h2><button id="load-report" class="rounded-2xl bg-slate-950 px-5 py-3 font-black text-white">Muat laporan</button></div><div id="report-box" class="mt-5">${S.report?reportHTML(S.report):'<p class="text-slate-500">Klik Muat laporan untuk melihat ringkasan penjualan, produk terlaris, dan stok rendah.</p>'}</div></div>`; }
function reportHTML(r){ const o=r.overview||{}; return `<div class="grid gap-4 md:grid-cols-4">${metricCard('Omzet',rupiah(o.gross_revenue),'fa-money-bill-trend-up')}${metricCard('Pesanan',o.total_orders||0,'fa-receipt')}${metricCard('Pelanggan',o.total_customers||0,'fa-users')}${metricCard('Stok rendah',o.low_stock||0,'fa-triangle-exclamation')}</div><div class="mt-6 grid gap-6 lg:grid-cols-2"><div><h3 class="font-black">Produk terlaris</h3><div class="mt-3 space-y-2">${(r.best_sellers||[]).map(x=>`<div class="flex justify-between rounded-2xl bg-slate-50 p-3 text-sm"><span><b>${esc(x.product_name)}</b><p class="text-xs text-slate-500">${esc(x.brand_name)} • ${x.qty} unit</p></span><b>${rupiah(x.revenue)}</b></div>`).join('')||'<p class="text-sm text-slate-500">Belum ada data.</p>'}</div></div><div><h3 class="font-black">Pesanan terbaru</h3><div class="mt-3 space-y-2">${(r.recent_orders||[]).map(x=>`<div class="rounded-2xl bg-slate-50 p-3 text-sm"><div class="flex justify-between"><b>ORD-${x.order_id}</b><b>${rupiah(x.total_amount)}</b></div><p class="mt-1 text-xs text-slate-500">${esc(x.order_date)} • ${esc(statusInfo(x.status).label)} • ${esc(x.payment_method)}</p></div>`).join('')||'<p class="text-sm text-slate-500">Belum ada data.</p>'}</div></div></div><div class="mt-6 grid gap-6 lg:grid-cols-2"><div><h3 class="font-black">Stok rendah</h3><div class="mt-3 space-y-2">${(r.low_stock||[]).slice(0,12).map(x=>`<div class="flex justify-between rounded-2xl bg-rose-50 p-3 text-sm"><span><b>${esc(x.product_name)}</b><p class="text-xs text-rose-500">${esc(x.brand_name)} • ${esc(x.color)} • ${esc(x.ram)}/${esc(x.storage)}</p></span><b class="text-rose-700">${x.stock} unit</b></div>`).join('')||'<p class="text-sm text-slate-500">Tidak ada stok rendah.</p>'}</div></div><div><h3 class="font-black">Status pesanan</h3><div class="mt-3 space-y-2">${(r.orders_by_status||[]).map(x=>`<div class="flex justify-between rounded-2xl bg-slate-50 p-3 text-sm"><b>${esc(statusInfo(x.status).label)}</b><span>${x.total} pesanan</span></div>`).join('')||'<p class="text-sm text-slate-500">Belum ada pesanan.</p>'}</div></div></div><div class="mt-6"><h3 class="font-black">Aktivitas terbaru</h3><div class="mt-3 grid gap-2">${(r.activity_log||[]).map(x=>`<div class="rounded-2xl bg-slate-50 p-3 text-sm"><b>${esc(x.full_name||'Sistem')}</b><p class="text-slate-500">${esc(x.activity)}</p><p class="text-xs text-slate-400">${esc(x.activity_time)}</p></div>`).join('')||'<p class="text-sm text-slate-500">Belum ada aktivitas.</p>'}</div></div>`; }

function initHeroSlider(){
  // Autoplay dibuat sengaja tetap jalan meskipun cursor berada di area slider.
  // Versi sebelumnya berhenti saat hover, jadi terlihat seperti harus digeser manual.
  if(S.heroTimer){ clearTimeout(S.heroTimer); clearInterval(S.heroTimer); S.heroTimer=null; }
  const widget=document.querySelector('[data-hero-widget]');
  const track=document.querySelector('[data-hero-slider]');
  if(!widget || !track) return;
  const slides=[...track.querySelectorAll('.hero-slide')];
  const dots=[...widget.querySelectorAll('.hero-dot')];
  const progress=widget.querySelector('.slide-progress');
  if(slides.length<=1) return;

  let idx=0;
  const delay=3800;

  const restartProgress=()=>{
    if(!progress) return;
    progress.classList.remove('play');
    void progress.offsetWidth;
    progress.classList.add('play');
  };

  const show=(next)=>{
    idx=(next+slides.length)%slides.length;
    track.style.transform=`translateX(-${idx*100}%)`;
    dots.forEach((d,i)=>d.classList.toggle('active',i===idx));
    restartProgress();
  };

  const startAuto=()=>{
    if(S.heroTimer){ clearTimeout(S.heroTimer); clearInterval(S.heroTimer); }
    S.heroTimer=setTimeout(()=>{
      show(idx+1);
      startAuto();
    },delay);
  };

  const manual=(next)=>{
    show(next);
    startAuto();
  };

  widget.querySelector('[data-hero-next]')?.addEventListener('click',()=>manual(idx+1));
  widget.querySelector('[data-hero-prev]')?.addEventListener('click',()=>manual(idx-1));
  dots.forEach(d=>d.addEventListener('click',()=>manual(Number(d.dataset.heroDot||0))));

  show(0);
  startAuto();

  document.addEventListener('visibilitychange',()=>{
    if(document.hidden){
      if(S.heroTimer){ clearTimeout(S.heroTimer); clearInterval(S.heroTimer); S.heroTimer=null; }
    }else{
      startAuto();
    }
  },{once:false});
}
function initCounters(){
  document.querySelectorAll('.js-count').forEach(el=>{
    const target=Number(el.dataset.count||0); let current=0; const steps=28; const inc=Math.max(1,Math.ceil(target/steps));
    const tick=()=>{ current=Math.min(target,current+inc); el.textContent=current.toLocaleString('id-ID'); if(current<target) requestAnimationFrame(tick); };
    tick();
  });
}

function bindPage(page){
  syncNav(); document.querySelectorAll('.detail-go').forEach(b=>b.onclick=()=>{S.currentProductId=b.dataset.product; renderPage('detail')}); bindProductButtons();
  if(page==='home'){ initHeroSlider(); initCounters(); } if(page==='catalog') bindCatalog(); if(page==='detail') bindDetail(); if(page==='cart') bindCart(); if(page==='checkout') bindCheckout(); if(page==='wishlist') bindWishlist(); if(page==='history') bindHistory(); if(page==='invoice') bindInvoice(); if(page==='login') bindLogin('customer'); if(page==='login-admin') bindLogin('admin'); if(page==='profile') bindProfile(); if(page==='admin') bindAdmin(); updateUI();
}
function bindProductButtons(){
  document.querySelectorAll('.add-cart').forEach(b=>b.onclick=async()=>{ if(!requireUser()) return; const qty=Number(document.getElementById('detail-qty')?.value||1); try{ const d=await postJSON('api_cart.php',{action:'add',user_id:S.currentUser.user_id,variant_id:Number(b.dataset.variant),quantity:qty}); S.cartItems=d.data.cart||[]; updateUI(); toast('Produk masuk keranjang.'); }catch(e){toast(e.message,'error')} });
  document.querySelectorAll('.toggle-wish').forEach(b=>b.onclick=async()=>{ if(!requireUser()) return; try{ const d=await postJSON('api_wishlist.php',{action:'toggle',user_id:S.currentUser.user_id,variant_id:Number(b.dataset.variant)}); S.wishlist=d.data.wishlist||[]; updateUI(); toast(d.message); bindProductButtons(); renderPage(S.currentPage); }catch(e){toast(e.message,'error')} });
}
function bindCatalog(){
  document.getElementById('catalog-search').oninput=e=>{S.search=e.target.value; renderPage('catalog')}; document.getElementById('catalog-sort').onchange=e=>{S.sort=e.target.value; renderPage('catalog')};
  document.querySelectorAll('.brand-chip').forEach(b=>b.onclick=()=>{const val=b.dataset.brand; S.filters.brands=S.filters.brands.includes(val)?S.filters.brands.filter(x=>x!==val):[...S.filters.brands,val]; renderPage('catalog')});
  document.querySelectorAll('.cat-filter').forEach(c=>c.onchange=()=>{S.filters.categories=[...document.querySelectorAll('.cat-filter:checked')].map(x=>x.value); renderPage('catalog')});
  document.querySelectorAll('.ram-filter').forEach(c=>c.onchange=()=>{S.filters.rams=[...document.querySelectorAll('.ram-filter:checked')].map(x=>x.value); renderPage('catalog')});
  document.querySelectorAll('.storage-filter').forEach(c=>c.onchange=()=>{S.filters.storages=[...document.querySelectorAll('.storage-filter:checked')].map(x=>x.value); renderPage('catalog')});
  document.getElementById('filter-min').onchange=e=>{S.filters.minPrice=Number(e.target.value||0); renderPage('catalog')}; document.getElementById('filter-max').onchange=e=>{S.filters.maxPrice=Number(e.target.value||30000000); renderPage('catalog')}; document.getElementById('stock-only').onchange=e=>{S.filters.stockOnly=e.target.checked; renderPage('catalog')}; document.getElementById('reset-filter').onclick=()=>{resetCatalogFilters();renderPage('catalog')};
}
function bindDetail(){ document.querySelectorAll('.variant-btn').forEach(b=>b.onclick=()=>{S.selectedVariantByProductId[b.dataset.product]=Number(b.dataset.variant); renderPage('detail')}); document.getElementById('detail-qty').onchange=e=>S.selectedQty=Math.max(1,Number(e.target.value||1)); }
function bindCart(){ document.getElementById('refresh-cart').onclick=async()=>{await loadCart(); renderPage('cart')}; document.querySelectorAll('.cart-qty').forEach(i=>i.onchange=async()=>{try{const d=await postJSON('api_cart.php',{action:'update',user_id:S.currentUser.user_id,cart_id:Number(i.dataset.cart),quantity:Number(i.value)});S.cartItems=d.data.cart||[];renderPage('cart');toast('Jumlah produk diperbarui.')}catch(e){toast(e.message,'error')}}); document.querySelectorAll('.remove-cart').forEach(b=>b.onclick=async()=>{try{const d=await postJSON('api_cart.php',{action:'remove',user_id:S.currentUser.user_id,cart_id:Number(b.dataset.cart)});S.cartItems=d.data.cart||[];renderPage('cart');toast('Item dihapus.')}catch(e){toast(e.message,'error')}}); document.getElementById('clear-cart').onclick=async()=>{try{const d=await postJSON('api_cart.php',{action:'clear',user_id:S.currentUser.user_id});S.cartItems=d.data.cart||[];renderPage('cart');toast('Keranjang dikosongkan.')}catch(e){toast(e.message,'error')}}; }
function bindCheckout(){ document.querySelectorAll('input[name="payment"]').forEach(r=>r.onchange=e=>{S.checkout.paymentMethod=e.target.value; renderPage('checkout')}); document.getElementById('checkout-form').onsubmit=async e=>{e.preventDefault(); try{const payload={user_id:S.currentUser.user_id,cart_items:S.cartItems.map(i=>({variant_id:i.variant_id,quantity:i.quantity})),customer:{user_id:S.currentUser.user_id,name:val('co-name'),phone:val('co-phone'),email:S.currentUser.email,address:val('co-address')},shipping_address:val('co-address'),payment_method:S.checkout.paymentMethod,transfer_bank:document.getElementById('co-bank')?.value,ewallet_provider:document.getElementById('co-ewallet')?.value,card_name:document.getElementById('co-card-name')?.value,card_number:document.getElementById('co-card-number')?.value,shipping_cost:150000}; const d=await postJSON('api_checkout.php',payload); const orderId=Number(d.data.order_id); await fetchProduk(false); await loadCart(); await loadOrders(false); S.invoiceOrderId=orderId; toast(`Pesanan ${d.data.order_code} berhasil dibuat. Invoice siap dicetak.`); renderPage('invoice');}catch(err){toast(err.message,'error')}}; }
function bindWishlist(){ document.getElementById('refresh-wishlist').onclick=async()=>{await loadWishlist(); renderPage('wishlist')}; }
function bindHistory(){ document.getElementById('load-orders').onclick=()=>loadOrders(true); if(!S.orders.length) loadOrders(true); else bindOrderButtons(); }
async function loadOrders(paint=true){ const box=document.getElementById('orders-box'); if(box && paint) box.innerHTML=loading('Memuat pesanan','Mengambil riwayat pesanan Anda.'); try{const d=await getJSON(`api_orders.php?user_id=${S.currentUser.user_id}`); S.orders=d.data.orders||[]; if(box && paint){ box.innerHTML=ordersHTML(S.orders); bindOrderButtons(); }}catch(e){if(box) box.innerHTML=errorBox('Gagal memuat pesanan',e.message)} }
function bindOrderButtons(){ document.querySelectorAll('.open-invoice').forEach(b=>b.onclick=()=>{S.invoiceOrderId=Number(b.dataset.order); renderPage('invoice')}); }
function bindInvoice(){ const btn=document.getElementById('print-invoice'); if(btn) btn.onclick=()=>window.print(); if(!S.orders.length) loadOrders(false).then(()=>renderPage('invoice')).catch(e=>toast(e.message,'error')); }
function bindLogin(role){ document.getElementById('login-form').onsubmit=async e=>{e.preventDefault(); try{const d=await postJSON('api_login.php',{email:val('login-email'),password:val('login-password'),role}); if(role==='admin') S.currentAdmin=d.data.user; else {S.currentUser=d.data.user; await Promise.allSettled([loadCart(), loadWishlist()]);} saveUser(); toast(d.message); renderPage(role==='admin'?'admin':'home');}catch(err){toast(err.message,'error')}}; }
function bindProfile(){ document.getElementById('pf-email').disabled=true; document.getElementById('profile-form').onsubmit=async e=>{e.preventDefault(); try{const d=await postJSON('api_profile.php',{user_id:S.currentUser.user_id,full_name:val('pf-name'),phone:val('pf-phone'),address:val('pf-address'),city:val('pf-city'),province:val('pf-province')});S.currentUser=d.data.user;saveUser();toast('Profile tersimpan.');renderPage('profile')}catch(err){toast(err.message,'error')}}; }
function bindAdmin(){ document.querySelectorAll('.admin-tab').forEach(b=>b.onclick=()=>{S.adminTab=b.dataset.tab; renderPage('admin')}); document.getElementById('admin-refresh').onclick=async()=>{await fetchProduk(false);toast('Data admin diperbarui.');renderPage('admin')}; if(S.adminTab==='stock') bindAdminStok(); if(S.adminTab==='orders') bindAdminOrderPage(); if(S.adminTab==='products') bindAdminProduk(); if(S.adminTab==='reports') bindReport(); }
function bindAdminStok(){ const search=document.getElementById('admin-stock-search'); search.oninput=e=>{const q=e.target.value.toLowerCase(); const vars=S.variants.filter(v=>{const p=findProduct(v.product_id); return [p?.name,p?.brand,p?.category,v.color,v.ram,v.storage].join(' ').toLowerCase().includes(q)}); document.getElementById('admin-stock-box').innerHTML=stockTableRows(vars); bindAdminStokButtons();}; bindAdminStokButtons(); }
function bindAdminStokButtons(){ document.querySelectorAll('.stock-delta').forEach(b=>b.onclick=async()=>{try{const d=await postJSON('api_admin_product.php',{action:'adjust_stock',admin_id:S.currentAdmin.user_id,variant_id:Number(b.dataset.variantId),delta:Number(b.dataset.delta)}); S.adminTab='stock'; await fetchProduk(false); toast(`Stok diperbarui menjadi ${d.data?.stock ?? ''}.`); renderPage('admin');}catch(e){toast(e.message,'error')}}); document.querySelectorAll('.stock-set').forEach(b=>b.onclick=async()=>{try{const input=document.querySelector(`.stock-set-input[data-variant-id="${b.dataset.variantId}"]`); const stock=Number(input.value); if(!Number.isFinite(stock) || stock<0) throw new Error('Stok harus angka 0 atau lebih.'); const d=await postJSON('api_admin_product.php',{action:'set_stock',admin_id:S.currentAdmin.user_id,variant_id:Number(b.dataset.variantId),stock:stock}); S.adminTab='stock'; await fetchProduk(false); toast(`Stok disimpan: ${d.data?.stock ?? stock}.`); renderPage('admin');}catch(e){toast(e.message,'error')}}); }
function bindAdminOrderPage(){ document.getElementById('load-admin-orders').onclick=loadAdminOrders; if(!S.adminOrders.length) loadAdminOrders(); }
async function loadAdminOrders(){ const box=document.getElementById('admin-orders-box'); box.innerHTML=loading('Memuat semua pesanan','Mengambil daftar pesanan terbaru.'); try{const d=await getJSON(`api_orders.php?admin_id=${S.currentAdmin.user_id}`); S.adminOrders=d.data.orders||[]; box.innerHTML=adminOrdersHTML(S.adminOrders); bindAdminOrderStatus();}catch(e){box.innerHTML=errorBox('Gagal memuat pesanan',e.message)} }
function bindAdminOrderStatus(){ document.querySelectorAll('.order-status').forEach(s=>s.onchange=async()=>{try{await postJSON('api_orders.php',{admin_id:S.currentAdmin.user_id,order_id:Number(s.dataset.order),status:s.value});toast('Status pesanan tersimpan.');await loadAdminOrders();await fetchProduk(false);}catch(e){toast(e.message,'error')}}); }
function bindAdminProduk(){
  const fillProduct=()=>{
    const p=findProduct(document.getElementById('edit-product-select')?.value); if(!p)return;
    document.getElementById('edit-name').value=p.name;
    document.getElementById('edit-brand').value=p.brand;
    document.getElementById('edit-cat').value=p.category;
    document.getElementById('edit-year').value=p.release_year;
    document.getElementById('edit-base').value=p.base_price;
    S.justAddedProductId=idOfProduct(p);
    renderPage('admin');
  };
  const fillVariant=()=>{
    const v=findVariant(Number(document.getElementById('edit-variant-select')?.value)); if(!v)return;
    document.getElementById('edit-color').value=v.color;
    document.getElementById('edit-ram').value=v.ram;
    document.getElementById('edit-storage').value=v.storage;
    document.getElementById('edit-price').value=v.price;
    document.getElementById('edit-stock').value=v.stock;
  };
  const sel=document.getElementById('edit-product-select'); if(sel){ sel.onchange=fillProduct; }
  const vsel=document.getElementById('edit-variant-select'); if(vsel){ vsel.onchange=fillVariant; fillVariant(); }
  document.querySelectorAll('.admin-product-row').forEach(btn=>btn.onclick=()=>{S.justAddedProductId=btn.dataset.product; renderPage('admin')});
  const go=document.getElementById('go-catalog-from-admin'); if(go) go.onclick=()=>{resetCatalogFilters();renderPage('catalog')};
  document.getElementById('add-product-form').onsubmit=async e=>{e.preventDefault(); try{const d=await postJSON('api_admin_product.php',{action:'add_product',admin_id:S.currentAdmin.user_id,product_name:val('new-name'),brand:val('new-brand'),category:val('new-cat'),release_year:Number(val('new-year')),base_price:Number(val('new-base')),color:val('new-color'),ram:val('new-ram'),storage:val('new-storage'),price:Number(val('new-price')),stock:Number(val('new-stock')),display_inch:val('new-display'),chipset:val('new-chipset'),battery:val('new-battery'),camera:val('new-camera')}); S.justAddedProductId=d.data?.product_id || null; S.adminTab='products'; await fetchProduk(false); toast(`Produk ${S.justAddedProductId||''} berhasil ditambahkan dengan stok awal ${d.data?.stock ?? ''}.`); renderPage('admin');}catch(err){toast(err.message,'error')}};
  document.getElementById('edit-product-form').onsubmit=async e=>{e.preventDefault(); try{const pid=val('edit-product-select'); await postJSON('api_admin_product.php',{action:'update_product',admin_id:S.currentAdmin.user_id,product_id:pid,product_name:val('edit-name'),brand:val('edit-brand'),category:val('edit-cat'),release_year:Number(val('edit-year')),base_price:Number(val('edit-base'))}); S.justAddedProductId=pid; toast('Info produk berhasil diperbarui.'); await fetchProduk(false); renderPage('admin');}catch(err){toast(err.message,'error')}};
  document.getElementById('save-variant').onclick=async()=>{try{const variantId=Number(val('edit-variant-select')); if(!variantId) throw new Error('Varian belum dipilih.'); const d=await postJSON('api_admin_product.php',{action:'update_variant',admin_id:S.currentAdmin.user_id,variant_id:variantId,color:val('edit-color'),ram:val('edit-ram'),storage:val('edit-storage'),price:Number(val('edit-price')),stock:Number(val('edit-stock'))}); S.justAddedProductId=d.data?.product_id || val('edit-product-select'); await fetchProduk(false); toast(`Stok varian tersimpan: ${d.data?.stock ?? val('edit-stock')}.`); renderPage('admin');}catch(err){toast(err.message,'error')}};
  document.getElementById('delete-product').onclick=async()=>{ if(!confirm('Hapus produk ini? Tidak bisa jika sudah punya transaksi.')) return; try{await postJSON('api_admin_product.php',{action:'delete_product',admin_id:S.currentAdmin.user_id,product_id:val('edit-product-select')}); S.justAddedProductId=null; toast('Produk dihapus.'); await fetchProduk(false); renderPage('admin');}catch(err){toast(err.message,'error')}};
}

function bindReport(){ document.getElementById('load-report').onclick=loadReport; if(!S.report) loadReport(); }
async function loadReport(){ const box=document.getElementById('report-box'); box.innerHTML=loading('Memuat laporan...','Menyiapkan ringkasan penjualan terbaru.'); try{ const d=await getJSON('api_report.php'); S.report=d.data; box.innerHTML=reportHTML(S.report); }catch(e){box.innerHTML=errorBox('Gagal memuat laporan',e.message)} }
function val(id){return document.getElementById(id)?.value || ''}

window.onload = init;
</script>
</body>
</html>
